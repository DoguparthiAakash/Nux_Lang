# Integrative Verification Script for Nux Core Libraries
# Imports and validates all four libraries (Maths, Physics, Graph, Quantum)

import "std/io";
import "nux-libs/maths/maths";
import "nux-libs/physics/physics";
import "nux-libs/graph/graph";
import "nux-libs/quantum/circuit";

func test_maths() {
    println("==========================================");
    println("TESTING MATHS LIBRARY");
    println("==========================================");

    # 1. Complex Numbers
    var c1 = new ComplexNumber(3.0, 4.0);
    var c2 = new ComplexNumber(1.0, -2.0);
    var c_add = c1.add(&c2);
    var c_mul = c1.mul(&c2);
    println("Complex Number 1: " + c1.to_str());
    println("Complex Number 2: " + c2.to_str());
    println("Addition: " + c_add.to_str());
    println("Multiplication: " + c_mul.to_str());
    println("Magnitude (c1): " + float_to_str(c1.magnitude()));
    println("");

    # 2. Vector3D
    var v1 = new Vector3D(1.0, 2.0, 3.0);
    var v2 = new Vector3D(4.0, 5.0, 6.0);
    var v_dot = v1.dot(&v2);
    var v_cross = v1.cross(&v2);
    println("Vector 1: " + v1.to_str());
    println("Vector 2: " + v2.to_str());
    println("Dot Product: " + float_to_str(v_dot));
    println("Cross Product: " + v_cross.to_str());
    println("");

    # 3. Matrix & Linear Systems Solver
    # Solve A x = b:
    # 2x + 1y = 5
    # 1x + 3y = 5
    # Solution: x = 2, y = 1
    var mat_data = [2.0, 1.0, 1.0, 3.0];
    var A = new Matrix(2, 2, mat_data);
    var b = [5.0, 5.0];
    println("Matrix A:\n" + A.to_str());
    
    var x = A.solve(b);
    println("Solving A x = [5, 5]^T...");
    println("Solution x = [" + float_to_str(x[0]) + ", " + float_to_str(x[1]) + "]");
    
    var A_inv = A.inverse();
    println("Inverse of A:\n" + A_inv.to_str());
    println("");

    # 4. Numerical Calculus
    # f(x) = x^2, f'(3) = 6, \int_0^3 x^2 dx = 9
    var f = func(x: float) -> float {
        return x * x;
    };
    var df_dx = derivative(f, 3.0, 0.0001);
    var integral = integrate(f, 0.0, 3.0, 1000);
    println("Numerical Calculus: f(x) = x^2");
    println("Derivative at x = 3: " + float_to_str(df_dx) + " (Expected: 6.0)");
    println("Integral from 0 to 3: " + float_to_str(integral) + " (Expected: 9.0)");
}

func test_physics() {
    println("==========================================");
    println("TESTING PHYSICS LIBRARY");
    println("==========================================");

    # Kinematics
    var k = new Kinematics();
    var s = k.displacement(0.0, PhysicsConstants.G_EARTH, 3.0); # s = 0.5 * 9.8 * 9 = 44.1
    println("Earth gravity displacement (t=3s, v0=0): " + float_to_str(s) + " m");

    # Newtonian Dynamics
    var dyn = new Dynamics();
    var f = dyn.force(80.0, 2.5); # F = 80 * 2.5 = 200 N
    var esc_v = dyn.escape_velocity(5.972e24, 6.371e6); # Earth escape velocity ~ 11186 m/s
    println("Force (80kg at 2.5m/s^2): " + float_to_str(f) + " N");
    println("Earth Escape Velocity: " + float_to_str(esc_v) + " m/s");

    # Special Relativity
    var rel = new SpecialRelativity();
    var time_dilated = rel.time_dilation(1.0, 0.9 * PhysicsConstants.C); # 90% speed of light
    println("Relativistic time dilation at 90% speed of light: " + float_to_str(time_dilated) + "s per 1s proper time");
}

func test_graph() {
    println("==========================================");
    println("TESTING GRAPH LIBRARY");
    println("==========================================");

    # Create a graph of 5 vertices
    # 0 -- 1 \
    # |    |  3
    # 2 -- 4 /
    var g = new Graph(5, false); # Undirected
    g.add_edge(0, 1, 1.0);
    g.add_edge(0, 2, 2.0);
    g.add_edge(1, 3, 3.0);
    g.add_edge(2, 4, 1.5);
    g.add_edge(3, 4, 2.0);
    g.add_edge(1, 4, 2.5);

    # BFS & DFS
    var bfs_order = g.bfs(0);
    var dfs_order = g.dfs(0);
    
    var bfs_str = "[";
    for (var i = 0; i < bfs_order.len(); i += 1) {
        bfs_str += int_to_str(bfs_order[i]) + if (i == bfs_order.len() - 1) "" else ", ";
    }
    bfs_str += "]";
    
    var dfs_str = "[";
    for (var i = 0; i < dfs_order.len(); i += 1) {
        dfs_str += int_to_str(dfs_order[i]) + if (i == dfs_order.len() - 1) "" else ", ";
    }
    dfs_str += "]";

    println("BFS Travseral from 0: " + bfs_str);
    println("DFS Traversal from 0: " + dfs_str);

    # Shortest Path (Dijkstra)
    # Path from 0 to 3 should be 0 -> 1 -> 3 (cost = 4.0) or 0 -> 2 -> 4 -> 3 (cost = 2 + 1.5 + 2 = 5.5)
    var shortest_path = g.dijkstra(0, 3);
    var sp_str = "[";
    for (var i = 0; i < shortest_path.len(); i += 1) {
        sp_str += int_to_str(shortest_path[i]) + if (i == shortest_path.len() - 1) "" else " -> ";
    }
    sp_str += "]";
    println("Dijkstra Shortest Path 0 to 3: " + sp_str);
    
    # Topological Sort (Directed Graph)
    # 0 -> 1 -> 2
    #   \-> 3 -> 2
    var dep_graph = new Graph(4, true); # Directed
    dep_graph.add_edge(0, 1);
    dep_graph.add_edge(0, 3);
    dep_graph.add_edge(1, 2);
    dep_graph.add_edge(3, 2);
    var topo_order = dep_graph.topological_sort();
    
    var topo_str = "[";
    for (var i = 0; i < topo_order.len(); i += 1) {
        topo_str += int_to_str(topo_order[i]) + if (i == topo_order.len() - 1) "" else ", ";
    }
    topo_str += "]";
    println("Topological Sort: " + topo_str);
}

func test_quantum() {
    println("==========================================");
    println("TESTING QUANTUM LIBRARY");
    println("==========================================");
    
    main(); # Invokes the built-in circuit.nux tests
}

func run_all_tests() {
    test_maths();
    println("");
    test_physics();
    println("");
    test_graph();
    println("");
    test_quantum();
    println("");
    println("==========================================");
    println("ALL CORE LIBRARY TESTS COMPLETED!");
    println("==========================================");
}

run_all_tests();
