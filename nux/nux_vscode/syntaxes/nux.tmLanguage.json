{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Nux",
    "scopeName": "source.nux",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#types"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#variables"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.number-sign.nux",
                    "match": "#.*$"
                },
                {
                    "name": "comment.block.nux",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.nux",
                    "match": "\\b(if|else|while|for|return|break|continue|import|as|from|in|do)\\b"
                },
                {
                    "name": "keyword.declaration.nux",
                    "match": "\\b(class|func|var|let|const|struct|enum)\\b"
                },
                {
                    "name": "keyword.other.nux",
                    "match": "\\b(this|super|new|spawn|lock|unlock|peek|poke|asm)\\b"
                },
                {
                    "name": "constant.language.boolean.nux",
                    "match": "\\b(true|false|null)\\b"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.nux",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.nux",
                    "match": "\\\\."
                }
            ]
        },
        "numbers": {
            "name": "constant.numeric.nux",
            "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.nux",
                    "match": "\\b(int|float|string|bool|void|char|byte|short|long)\\b"
                },
                {
                    "name": "support.class.nux",
                    "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.nux",
                    "match": "\\b[a-z][a-zA-Z0-9_]*(?=\\()"
                },
                {
                    "name": "support.function.nux",
                    "match": "\\b(print|println|input|sleep|assert|mem_alloc|mem_free|load_library)\\b"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.nux",
                    "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}