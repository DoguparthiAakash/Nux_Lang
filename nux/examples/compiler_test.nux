// Example Nux Program
// Test program for self-hosting compiler

fn fibonacci(n) {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

fn factorial(n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

fn main() {
    print("Nux Self-Hosting Compiler Test");
    print("================================");
    
    // Test variables
    let x = 10;
    let y = 20;
    let sum = x + y;
    print("10 + 20 = ");
    print(sum);
    
    // Test functions
    let fib10 = fibonacci(10);
    print("Fibonacci(10) = ");
    print(fib10);
    
    let fact5 = factorial(5);
    print("Factorial(5) = ");
    print(fact5);
    
    // Test control flow
    let i = 0;
    while (i < 5) {
        print(i);
        i = i + 1;
    }
    
    // Test for loop
    for (let j = 0; j < 3; j = j + 1) {
        print("Loop: ");
        print(j);
    }
    
    print("Test complete!");
}

main();
