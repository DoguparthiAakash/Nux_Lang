// Nux - Compile-Time Execution (comptime)
// Run arbitrary code at compile time!

// Compile-time function execution
comptime func generate_lookup_table(size: int) -> [int] {
    var table: [int] = [];
    for (var i = 0; i < size; i++) {
        table.push(i * i);
    }
    return table;
}

// Generated at compile time, stored in binary!
const SQUARES: [int] = generate_lookup_table(1000);

// Compile-time code generation
comptime func generate_getters(fields: [string]) -> string {
    var code = "";
    for (var field in fields) {
        code += "func get_" + field + "() -> auto { return this." + field + "; }\n";
    }
    return code;
}

// Metaprogramming with comptime
class Person {
    var name: string;
    var age: int;
    var email: string;
    
    // Generate getters at compile time!
    @comptime_eval(generate_getters(["name", "age", "email"]))
}

// Compile-time reflection
comptime func get_field_names<T>() -> [string] {
    var type_info = @type_info(T);
    var fields: [string] = [];
    for (var field in type_info.fields) {
        fields.push(field.name);
    }
    return fields;
}

// Compile-time assertions
comptime func assert_size<T>(expected: int) {
    var actual = @size_of(T);
    if (actual != expected) {
        @compile_error("Size mismatch: expected " + expected + ", got " + actual);
    }
}

// Use it
comptime assert_size<int>(8);  // OK on 64-bit
// comptime assert_size<int>(4);  // Compile error!

// Compile-time string manipulation
comptime func to_upper(s: string) -> string {
    var result = "";
    for (var c in s) {
        if (c >= 'a' && c <= 'z') {
            result += char(c - 32);
        } else {
            result += c;
        }
    }
    return result;
}

const GREETING: string = to_upper("hello");  // "HELLO"

// Compile-time parsing
comptime func parse_csv(data: string) -> [[string]] {
    var rows: [[string]] = [];
    var lines = data.split("\n");
    
    for (var line in lines) {
        var cols = line.split(",");
        rows.push(cols);
    }
    
    return rows;
}

// Parse CSV at compile time!
const DATA: [[string]] = parse_csv(@embed_file("data.csv"));

// Compile-time code optimization
comptime func optimize_loop<comptime N: int>(f: func(int) -> void) {
    if (N < 10) {
        // Unroll small loops
        @unroll for (var i = 0; i < N; i++) {
            f(i);
        }
    } else {
        // Keep large loops
        for (var i = 0; i < N; i++) {
            f(i);
        }
    }
}

// Compile-time type generation
comptime func generate_tuple_type(types: [Type]) -> Type {
    var fields = "";
    for (var i = 0; i < types.length; i++) {
        fields += "var field" + i + ": " + types[i].name + ";\n";
    }
    
    return @create_type("Tuple" + types.length, fields);
}

// Generic programming with comptime
func serialize<T>(value: T) -> string {
    comptime var type_info = @type_info(T);
    
    if (type_info.kind == TypeKind.Struct) {
        var json = "{";
        comptime for (var field in type_info.fields) {
            json += "\"" + field.name + "\": ";
            json += serialize(@field(value, field.name));
            json += ",";
        }
        json += "}";
        return json;
    } else if (type_info.kind == TypeKind.Int) {
        return to_string(value);
    } else if (type_info.kind == TypeKind.String) {
        return "\"" + value + "\"";
    }
    
    @compile_error("Cannot serialize type: " + type_info.name);
}

// Compile-time interface implementation
comptime func impl_trait<T>(trait: Trait, methods: [Method]) {
    for (var method in methods) {
        @add_method(T, method.name, method.body);
    }
}

// Compile-time memory layout optimization
comptime func optimize_struct_layout<T>() -> Type {
    var fields = @type_info(T).fields;
    
    // Sort fields by size (largest first) to minimize padding
    fields.sort((a, b) => @size_of(b.type) - @size_of(a.type));
    
    return @create_type(T.name + "Optimized", fields);
}

// Compile-time constant folding
comptime func compute_constants() {
    const PI = 3.14159265359;
    const E = 2.71828182846;
    const PHI = 1.61803398875;
    
    // All computed at compile time!
    const CIRCLE_AREA = PI * 10 * 10;
    const EXPONENTIAL = E * E * E;
}

// Example usage
func test_comptime() {
    // Lookup table generated at compile time
    var square_of_42 = SQUARES[42];  // No computation!
    
    // Reflection
    var fields = get_field_names<Person>();
    println(fields);  // ["name", "age", "email"]
    
    // Serialization
    var person = Person { name: "Alice", age: 30, email: "alice@example.com" };
    var json = serialize(person);
    println(json);  // {"name": "Alice", "age": 30, "email": "alice@example.com"}
}
