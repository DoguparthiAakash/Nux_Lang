// Nux - Formal Verification
// Prove program correctness at compile time!

// Contracts with pre/postconditions
func binary_search<T>(arr: [T], target: T) -> Option<int>
    requires is_sorted(arr)  // Precondition
    ensures match result {
        Some(i) => arr[i] == target && i >= 0 && i < arr.length,
        None => forall i in 0..arr.length: arr[i] != target
    }  // Postcondition
{
    var low = 0;
    var high = arr.length - 1;
    
    while (low <= high)
        invariant low >= 0 && high < arr.length  // Loop invariant
        invariant forall i in 0..low: arr[i] < target
        invariant forall i in high+1..arr.length: arr[i] > target
    {
        var mid = (low + high) / 2;
        
        if (arr[mid] == target) {
            return Some(mid);
        } else if (arr[mid] < target) {
            low = mid + 1;
        } else {
            high = mid - 1;
        }
    }
    
    return None;
}

// Verified sorting
func insertion_sort<T>(arr: [T]) -> [T]
    ensures is_sorted(result)
    ensures is_permutation(arr, result)
    ensures result.length == arr.length
{
    var result = arr.clone();
    
    for (var i = 1; i < result.length; i++)
        invariant is_sorted(result[0..i])
    {
        var key = result[i];
        var j = i - 1;
        
        while (j >= 0 && result[j] > key)
            invariant forall k in 0..j: result[k] <= result[k+1]
        {
            result[j + 1] = result[j];
            j -= 1;
        }
        
        result[j + 1] = key;
    }
    
    return result;
}

// Ghost variables (exist only for verification)
func sum_array(arr: [int]) -> int
    ensures result == ghost_sum(arr, 0, arr.length)
{
    ghost var partial_sum = 0;  // Only for proof
    var sum = 0;
    
    for (var i = 0; i < arr.length; i++)
        invariant sum == ghost_sum(arr, 0, i)
        invariant partial_sum == sum  // Ghost equality
    {
        sum += arr[i];
        ghost partial_sum += arr[i];
    }
    
    return sum;
}

