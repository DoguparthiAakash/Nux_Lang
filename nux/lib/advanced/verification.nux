// Dependent pairs (Sigma types)
class Exists<T, P: T -> bool> {
    var value: T;
    ghost var proof: P(value);
    
    func new(v: T) -> Exists<T, P>
        requires P(v)
    {
        return Exists<T, P> { value: v, proof: P(v) };
    }
}

// Example: even number with proof
type EvenNumber = Exists<int, (x) => x % 2 == 0>;

func create_even(n: int) -> Option<EvenNumber>
    ensures match result {
        Some(e) => e.value % 2 == 0,
        None => n % 2 != 0
    }
{
    if (n % 2 == 0) {
        return Some(EvenNumber.new(n));
    } else {
        return None;
    }
}

// Hoare logic
@hoare_triple(
    pre: x >= 0,
    post: result * result <= x && (result + 1) * (result + 1) > x
)
func integer_sqrt(x: int) -> int {
    var result = 0;
    
    while ((result + 1) * (result + 1) <= x)
        invariant result * result <= x
    {
        result += 1;
    }
    
    return result;
}

// Separation logic for memory safety
func swap<T>(a: &mut T, b: &mut T)
    requires a != b  // Pointers must be distinct
    ensures *a == old(*b) && *b == old(*a)
{
    var temp = *a;
    *a = *b;
    *b = temp;
}

// Termination proofs
func gcd(a: int, b: int) -> int
    requires a > 0 && b > 0
    ensures result > 0
    ensures a % result == 0 && b % result == 0
    decreases b  // Termination metric
{
    if (b == 0) {
        return a;
    } else {
        return gcd(b, a % b);  // b decreases
    }
}

// Inductive proofs
lemma func sum_n_formula(n: int)
    requires n >= 0
    ensures sum_range(0, n) == n * (n + 1) / 2
    decreases n
{
    if (n == 0) {
        // Base case
        assert sum_range(0, 0) == 0;
    } else {
        // Inductive case
        sum_n_formula(n - 1);  // Inductive hypothesis
        assert sum_range(0, n) == sum_range(0, n-1) + n;
        assert sum_range(0, n-1) == (n-1) * n / 2;
        assert sum_range(0, n) == (n-1) * n / 2 + n;
        assert sum_range(0, n) == n * (n + 1) / 2;
    }
}

// Abstract interpretation
@abstract_domain(Interval)
func abs_value(x: int) -> int
    ensures result >= 0
    ensures result == x || result == -x
{
    if (x >= 0) {
        return x;
    } else {
        return -x;
    }
}

// Model checking
@model_check(
    states: [Unlocked, Locked],
    initial: Unlocked,
    properties: [
        "always eventually Unlocked",
        "never (Locked && Unlocked)"
    ]
)
class Mutex {
    state Unlocked {
        func lock(consume this) -> Mutex<Locked> {
            return Mutex<Locked>.new();
        }
    }
    
    state Locked {
        func unlock(consume this) -> Mutex<Unlocked> {
            return Mutex<Unlocked>.new();
        }
    }
}

// SMT solver integration
@verify_with_z3
func max3(a: int, b: int, c: int) -> int
    ensures result >= a && result >= b && result >= c
    ensures result == a || result == b || result == c
{
    var max_ab = if (a > b) a else b;
    return if (max_ab > c) max_ab else c;
}

