// Example: Bell state (entanglement)
func create_bell_state() -> [Qubit] {
    var circuit = QuantumCircuit.new();
    var q0 = circuit.add_qubit();
    var q1 = circuit.add_qubit();
    
    // Create entanglement
    circuit.h(q0);
    circuit.cnot(q0, q1);
    
    return [circuit.qubits[q0], circuit.qubits[q1]];
}

// Quantum teleportation
func quantum_teleport(state: Qubit) -> Qubit {
    var circuit = QuantumCircuit.new();
    
    // Create Bell pair
    var alice_bell = circuit.add_qubit();
    var bob_bell = circuit.add_qubit();
    circuit.h(alice_bell);
    circuit.cnot(alice_bell, bob_bell);
    
    // Alice's operations
    var alice_state = circuit.add_qubit();
    circuit.qubits[alice_state] = state;
    
    circuit.cnot(alice_state, alice_bell);
    circuit.h(alice_state);
    
    // Measure Alice's qubits
    var m1 = circuit.measure(alice_state);
    var m2 = circuit.measure(alice_bell);
    
    // Bob's corrections
    if (m2 == 1) circuit.x(bob_bell);
    if (m1 == 1) circuit.z(bob_bell);
    
    return circuit.qubits[bob_bell];
}

