// Machine Learning - Complete ML library

// ============= LINEAR REGRESSION =============

class LinearRegression {
    var weights: [float];
    var bias: float = 0.0;
    var learning_rate: float = 0.01;
    
    func fit(X: [[float]], y: [float], epochs: int = 1000) {
        var n_features = X[0].length;
        this.weights = Array.filled(n_features, 0.0);
        
        for (var epoch = 0; epoch < epochs; epoch++) {
            for (var i = 0; i < X.length; i++) {
                var prediction = this.predict_one(X[i]);
                var error = prediction - y[i];
                
                // Update weights
                for (var j = 0; j < n_features; j++) {
                    this.weights[j] -= this.learning_rate * error * X[i][j];
                }
                
                this.bias -= this.learning_rate * error;
            }
        }
    }
    
    func predict(X: [[float]]) -> [float] {
        return X.map((x) => this.predict_one(x));
    }
    
    func predict_one(x: [float]) -> float {
        var sum = this.bias;
        for (var i = 0; i < x.length; i++) {
            sum += this.weights[i] * x[i];
        }
        return sum;
    }
}

// ============= LOGISTIC REGRESSION =============

class LogisticRegression {
    var weights: [float];
    var bias: float = 0.0;
    var learning_rate: float = 0.01;
    
    func sigmoid(z: float) -> float {
        return 1.0 / (1.0 + exp(-z));
    }
    
    func fit(X: [[float]], y: [float], epochs: int = 1000) {
        var n_features = X[0].length;
        this.weights = Array.filled(n_features, 0.0);
        
        for (var epoch = 0; epoch < epochs; epoch++) {
            for (var i = 0; i < X.length; i++) {
                var z = this.bias;
                for (var j = 0; j < n_features; j++) {
                    z += this.weights[j] * X[i][j];
                }
                
                var prediction = this.sigmoid(z);
                var error = prediction - y[i];
                
                for (var j = 0; j < n_features; j++) {
                    this.weights[j] -= this.learning_rate * error * X[i][j];
                }
                
                this.bias -= this.learning_rate * error;
            }
        }
    }
    
    func predict(X: [[float]]) -> [float] {
        return X.map((x) => {
            var z = this.bias;
            for (var i = 0; i < x.length; i++) {
                z += this.weights[i] * x[i];
            }
            return this.sigmoid(z);
        });
    }
}

// ============= K-MEANS CLUSTERING =============

class KMeans {
    var k: int;
    var centroids: [[float]];
    var max_iters: int = 100;
    
    func new(k: int) -> KMeans {
        return KMeans { k: k };
    }
    
    func fit(X: [[float]]) {
        // Initialize centroids randomly
        this.centroids = [];
        for (var i = 0; i < this.k; i++) {
            this.centroids.push(X[Random.range(0, X.length)]);
        }
        
        for (var iter = 0; iter < this.max_iters; iter++) {
            // Assign points to clusters
            var clusters: [[int]] = [];
            for (var i = 0; i < this.k; i++) {
                clusters.push([]);
            }
            
            for (var i = 0; i < X.length; i++) {
                var closest = this.find_closest_centroid(X[i]);
                clusters[closest].push(i);
            }
            
            // Update centroids
            for (var i = 0; i < this.k; i++) {
                if (clusters[i].length > 0) {
                    this.centroids[i] = this.compute_centroid(X, clusters[i]);
                }
            }
        }
    }
    
    func predict(X: [[float]]) -> [int] {
        return X.map((x) => this.find_closest_centroid(x));
    }
    
    func find_closest_centroid(point: [float]) -> int {
        var min_dist = INFINITY;
        var closest = 0;
        
        for (var i = 0; i < this.centroids.length; i++) {
            var dist = this.euclidean_distance(point, this.centroids[i]);
            if (dist < min_dist) {
                min_dist = dist;
                closest = i;
            }
        }
        
        return closest;
    }
    
    func euclidean_distance(a: [float], b: [float]) -> float {
        var sum = 0.0;
        for (var i = 0; i < a.length; i++) {
            sum += (a[i] - b[i]) * (a[i] - b[i]);
        }
        return sqrt(sum);
    }
    
    func compute_centroid(X: [[float]], indices: [int]) -> [float] {
        var n_features = X[0].length;
        var centroid: [float] = Array.filled(n_features, 0.0);
        
        for (var idx in indices) {
            for (var i = 0; i < n_features; i++) {
                centroid[i] += X[idx][i];
            }
        }
        
        for (var i = 0; i < n_features; i++) {
            centroid[i] /= indices.length;
        }
        
        return centroid;
    }
}

// ============= DECISION TREE =============

class DecisionTree {
    var root: Option<TreeNode> = None;
    var max_depth: int = 10;
    
    func fit(X: [[float]], y: [int]) {
        this.root = Some(this.build_tree(X, y, 0));
    }
    
    func build_tree(X: [[float]], y: [int], depth: int) -> TreeNode {
        // Check stopping criteria
        if (depth >= this.max_depth || y.all_equal()) {
            return TreeNode.leaf(most_common(y));
        }
        
        // Find best split
        var (feature, threshold) = this.find_best_split(X, y);
        
        // Split data
        var (X_left, y_left, X_right, y_right) = this.split_data(X, y, feature, threshold);
        
        // Recursively build subtrees
        var left = this.build_tree(X_left, y_left, depth + 1);
        var right = this.build_tree(X_right, y_right, depth + 1);
        
        return TreeNode.decision(feature, threshold, left, right);
    }
    
    func predict(X: [[float]]) -> [int] {
        return X.map((x) => this.predict_one(x, this.root.unwrap()));
    }
    
    func predict_one(x: [float], node: TreeNode) -> int {
        if (node.is_leaf) {
            return node.value;
        }
        
        if (x[node.feature] <= node.threshold) {
            return this.predict_one(x, node.left.unwrap());
        } else {
            return this.predict_one(x, node.right.unwrap());
        }
    }
}

// ============= NEURAL NETWORK =============

class NeuralNetwork {
    var layers: [Layer] = [];
    var learning_rate: float = 0.01;
    
    func add_layer(neurons: int, activation: string = "relu") {
        this.layers.push(Layer.new(neurons, activation));
    }
    
    func forward(input: [float]) -> [float] {
        var output = input;
        
        for (var layer in this.layers) {
            output = layer.forward(output);
        }
        
        return output;
    }
    
    func backward(loss_gradient: [float]) {
        var gradient = loss_gradient;
        
        for (var i = this.layers.length - 1; i >= 0; i--) {
            gradient = this.layers[i].backward(gradient, this.learning_rate);
        }
    }
    
    func train(X: [[float]], y: [[float]], epochs: int) {
        for (var epoch = 0; epoch < epochs; epoch++) {
            var total_loss = 0.0;
            
            for (var i = 0; i < X.length; i++) {
                var prediction = this.forward(X[i]);
                var loss = mse_loss(prediction, y[i]);
                total_loss += loss;
                
                var gradient = mse_gradient(prediction, y[i]);
                this.backward(gradient);
            }
            
            if (epoch % 100 == 0) {
                println("Epoch " + epoch + ", Loss: " + total_loss / X.length);
            }
        }
    }
}

class Layer {
    var weights: [[float]];
    var biases: [float];
    var activation: string;
    var last_input: [float];
    var last_output: [float];
    
    func forward(input: [float]) -> [float] {
        this.last_input = input;
        
        var output: [float] = [];
        for (var i = 0; i < this.weights.length; i++) {
            var sum = this.biases[i];
            for (var j = 0; j < input.length; j++) {
                sum += this.weights[i][j] * input[j];
            }
            output.push(this.activate(sum));
        }
        
        this.last_output = output;
        return output;
    }
    
    func activate(x: float) -> float {
        match (this.activation) {
            "relu" => max(0.0, x),
            "sigmoid" => 1.0 / (1.0 + exp(-x)),
            "tanh" => tanh(x),
            _ => x
        }
    }
}
