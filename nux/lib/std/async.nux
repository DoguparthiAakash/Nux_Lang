class Promise {
    var state;
    var value;
    var then_callbacks;
    var catch_callbacks;
    
    func init() {
        this.state = 0;
        this.then_callbacks = new List();
        this.then_callbacks.init();
        this.catch_callbacks = new List();
        this.catch_callbacks.init();
    }
    
    func then(callback) {
        if (this.state == 1) {
            callback(this.value);
        }
        if (this.state == 0) {
            this.then_callbacks.append(callback);
        }
        
        return this;
    }
    
    func catch(callback) {
        if (this.state == 2) {
            callback(this.value);
        }
        if (this.state == 0) {
            this.catch_callbacks.append(callback);
        }
        
        return this;
    }
    
    func resolve(val) {
        this.state = 1;
        this.value = val;
        
        var i = 0;
        for (i = 0; i < this.then_callbacks.length(); i = i + 1) {
            var cb = this.then_callbacks.get(i);
            cb(val);
        }
    }
    
    func reject(err) {
        this.state = 2;
        this.value = err;
        
        var i = 0;
        for (i = 0; i < this.catch_callbacks.length(); i = i + 1) {
            var cb = this.catch_callbacks.get(i);
            cb(err);
        }
    }
}
