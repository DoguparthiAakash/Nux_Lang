// Testing Framework - Comprehensive test utilities

// ============= TEST FRAMEWORK =============

class TestRunner {
    var tests: Vec<Test> = Vec.new();
    var passed: int = 0;
    var failed: int = 0;
    
    func register(name: string, test_fn: func() -> void) {
        this.tests.push(Test {
            name: name,
            test_fn: test_fn
        });
    }
    
    func run_all() {
        println("Running " + this.tests.length + " tests...\n");
        
        for (var test in this.tests.iter()) {
            print("Test " + test.name + " ... ");
            
            var result = this.run_test(test);
            
            if (result.is_ok()) {
                println("✓ PASSED");
                this.passed += 1;
            } else {
                println("✗ FAILED");
                println("  Error: " + result.unwrap_err());
                this.failed += 1;
            }
        }
        
        println("\n" + this.passed + " passed, " + this.failed + " failed");
        
        if (this.failed > 0) {
            exit(1);
        }
    }
    
    func run_test(test: Test) -> Result<(), string> {
        try {
            test.test_fn();
            return Ok(());
        } catch (e) {
            return Err(e.message);
        }
    }
}

struct Test {
    var name: string;
    var test_fn: func() -> void;
}

// ============= ASSERTIONS =============

func assert(condition: bool, message: string = "Assertion failed") {
    if (!condition) {
        throw Error(message);
    }
}

func assert_eq<T>(left: T, right: T, message: string = "") where T: Eq + Debug {
    if (left != right) {
        var msg = if (message.length() > 0) message 
                  else "Assertion failed: " + debug(left) + " != " + debug(right);
        throw Error(msg);
    }
}

func assert_ne<T>(left: T, right: T, message: string = "") where T: Eq + Debug {
    if (left == right) {
        var msg = if (message.length() > 0) message
                  else "Assertion failed: " + debug(left) + " == " + debug(right);
        throw Error(msg);
    }
}

func assert_ok<T, E>(result: Result<T, E>) where E: Debug {
    if (result.is_err()) {
        throw Error("Expected Ok, got Err: " + debug(result.unwrap_err()));
    }
}

func assert_err<T, E>(result: Result<T, E>) {
    if (result.is_ok()) {
        throw Error("Expected Err, got Ok");
    }
}

func assert_some<T>(option: Option<T>) {
    if (option.is_none()) {
        throw Error("Expected Some, got None");
    }
}

func assert_none<T>(option: Option<T>) where T: Debug {
    if (option.is_some()) {
        throw Error("Expected None, got Some: " + debug(option.unwrap()));
    }
}

// ============= PROPERTY-BASED TESTING =============

class PropertyTest<T> {
    var generator: func() -> T;
    var iterations: int = 100;
    
    static func for_all<T>(gen: func() -> T) -> PropertyTest<T> {
        return PropertyTest<T> {
            generator: gen,
            iterations: 100
        };
    }
    
    func iterations(n: int) -> PropertyTest<T> {
        this.iterations = n;
        return this;
    }
    
    func check(property: func(T) -> bool) -> Result<(), string> {
        for (var i = 0; i < this.iterations; i++) {
            var value = this.generator();
            
            if (!property(value)) {
                return Err("Property failed for: " + debug(value));
            }
        }
        
        return Ok(());
    }
}

// Generators
func gen_int(min: int, max: int) -> func() -> int {
    return () => Random.range(min, max);
}

func gen_string(max_len: int) -> func() -> string {
    return () => {
        var len = Random.range(0, max_len);
        var builder = StringBuilder.new();
        
        for (var i = 0; i < len; i++) {
            builder.append_char(Random.range('a', 'z') as char);
        }
        
        return builder.to_string();
    };
}

func gen_vec<T>(gen: func() -> T, max_len: int) -> func() -> Vec<T> {
    return () => {
        var len = Random.range(0, max_len);
        var vec = Vec<T>.new();
        
        for (var i = 0; i < len; i++) {
            vec.push(gen());
        }
        
        return vec;
    };
}

// ============= BENCHMARKING =============

class Benchmark {
    var name: string;
    var bench_fn: func() -> void;
    var iterations: int = 1000;
    
    static func new(name: string, bench_fn: func() -> void) -> Benchmark {
        return Benchmark {
            name: name,
            bench_fn: bench_fn,
            iterations: 1000
        };
    }
    
    func run() -> BenchResult {
        // Warmup
        for (var i = 0; i < 10; i++) {
            this.bench_fn();
        }
        
        // Measure
        var times: Vec<int> = Vec.new();
        
        for (var i = 0; i < this.iterations; i++) {
            var start = Time.now_nanos();
            this.bench_fn();
            var end = Time.now_nanos();
            
            times.push(end - start);
        }
        
        // Calculate statistics
        var total = times.fold(0, (acc, t) => acc + t);
        var mean = total / this.iterations;
        
        times.sort();
        var median = times.data[this.iterations / 2];
        var min = times.data[0];
        var max = times.data[this.iterations - 1];
        
        return BenchResult {
            name: this.name,
            iterations: this.iterations,
            mean_ns: mean,
            median_ns: median,
            min_ns: min,
            max_ns: max
        };
    }
}

struct BenchResult {
    var name: string;
    var iterations: int;
    var mean_ns: int;
    var median_ns: int;
    var min_ns: int;
    var max_ns: int;
    
    func print() {
        println("Benchmark: " + this.name);
        println("  Iterations: " + this.iterations);
        println("  Mean:   " + format_time(this.mean_ns));
        println("  Median: " + format_time(this.median_ns));
        println("  Min:    " + format_time(this.min_ns));
        println("  Max:    " + format_time(this.max_ns));
    }
}

// ============= MOCKING =============

class Mock<T> {
    var calls: Vec<Vec<any>> = Vec.new();
    var return_values: Vec<T> = Vec.new();
    var return_index: int = 0;
    
    func expect_call(args: Vec<any>) -> Mock<T> {
        this.calls.push(args);
        return this;
    }
    
    func returns(value: T) -> Mock<T> {
        this.return_values.push(value);
        return this;
    }
    
    func call(args: Vec<any>) -> T {
        this.calls.push(args);
        
        if (this.return_index < this.return_values.length) {
            var value = this.return_values.data[this.return_index];
            this.return_index += 1;
            return value;
        }
        
        panic("No more return values");
    }
    
    func verify() {
        // Verify expectations
    }
    
    func call_count() -> int {
        return this.calls.length;
    }
}

// ============= EXAMPLE USAGE =============

@test
func test_vec_push() {
    var vec = Vec<int>.new();
    vec.push(1);
    vec.push(2);
    vec.push(3);
    
    assert_eq(vec.length, 3);
    assert_eq(vec.get(0).unwrap(), 1);
    assert_eq(vec.get(1).unwrap(), 2);
    assert_eq(vec.get(2).unwrap(), 3);
}

@test
func test_hashmap() {
    var map = HashMap<string, int>.new();
    map.insert("one", 1);
    map.insert("two", 2);
    
    assert_eq(map.get("one").unwrap(), 1);
    assert_eq(map.get("two").unwrap(), 2);
    assert_none(map.get("three"));
}

@test
func test_property_reverse_twice() {
    PropertyTest.for_all(gen_vec(gen_int(0, 100), 20))
        .iterations(100)
        .check((vec) => {
            var original = vec.clone();
            vec.reverse();
            vec.reverse();
            return vec == original;
        })
        .unwrap();
}

@benchmark
func bench_vec_push() {
    var vec = Vec<int>.new();
    for (var i = 0; i < 1000; i++) {
        vec.push(i);
    }
}
