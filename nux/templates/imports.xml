<?xml version="1.0" encoding="UTF-8"?>
<!--
  Nux Import Manager — imports.xml
  Manages all imports, LAG bindings, and external libraries for a Nux project.
  
  Usage:
    - Place this file in your project root (applies to all files)
    - Or place a custom imports.xml in a subfolder (applies only to that folder)
    - Or reference a custom XML in any .nux file:
        @imports("config/my_imports.xml");
  
  Package naming convention:
    nux.<domain>.<name>       — Nux standard library
    com.<org>.<lib>           — Community library
    lang.<language>.<module>  — LAG language binding
-->
<nux-imports version="2.0">

  <!-- ═══════════════════════════════════════════════════════════════
       PROJECT METADATA
  ═══════════════════════════════════════════════════════════════ -->
  <project>
    <name>my-nux-project</name>
    <version>0.1.0</version>
    <package>com.example.myproject</package>
    <description>A Nux project</description>
    <author>Your Name</author>
    <license>MIT</license>
  </project>

  <!-- ═══════════════════════════════════════════════════════════════
       NUX STANDARD LIBRARY IMPORTS
       Format: <import pkg="nux.<lib>" as="alias" />
  ═══════════════════════════════════════════════════════════════ -->
  <nux-libs>
    <!-- Core types — always available, listed for explicitness -->
    <import pkg="nux.core.types"    as="types"   auto="true" />
    <import pkg="nux.core.io"       as="io"      auto="true" />
    <import pkg="nux.core.string"   as="string"  auto="true" />
    <import pkg="nux.core.math"     as="math"    auto="true" />

    <!-- AI / ML / DL -->
    <import pkg="nux.ai.tensor"     as="tensor"  />
    <import pkg="nux.ai.nn"         as="nn"      />
    <import pkg="nux.ai.optim"      as="optim"   />
    <import pkg="nux.ai.ml.models"  as="ml"      />
    <import pkg="nux.ai.dl.models"  as="dl"      />

    <!-- Quantum -->
    <import pkg="nux.quantum.circuit"             as="qc"     />
    <import pkg="nux.quantum.simulate"            as="qsim"   />
    <import pkg="nux.quantum.algorithms"          as="qalgo"  />

    <!-- OS / Systems -->
    <import pkg="nux.os.memory"     as="mem"     />
    <import pkg="nux.os.syscall"    as="sys"     />
    <import pkg="nux.os.interrupt"  as="irq"     />
  </nux-libs>

  <!-- ═══════════════════════════════════════════════════════════════
       LANGUAGE AGNOSTIC GATEWAY (LAG) BINDINGS
       Format: <lang name="python" version="3.13.7" alias="py" />
       These emit:  import nux.lag.python.3.13.7;
                    nux.lag python.3.13.7 = py;
  ═══════════════════════════════════════════════════════════════ -->
  <lag-bindings>
    <!-- Uncomment the languages you need -->
    <!-- <lang name="python" version="3.13.7" alias="py">
           <from-import module="os"       />
           <from-import module="sys"      />
           <from-import module="pathlib"  />
           <from-import module="numpy"    as="np" />
         </lang> -->

    <!-- <lang name="rust"   version="1.78"   alias="rs" /> -->
    <!-- <lang name="c"      version="17"     alias="c"  /> -->
    <!-- <lang name="java"   version="21"     alias="jv" /> -->
    <!-- <lang name="zig"    version="0.14"   alias="zg" /> -->
    <!-- <lang name="go"     version="1.22"   alias="go" /> -->
    <!-- <lang name="js"     version="20"     alias="js" /> -->
  </lag-bindings>

  <!-- ═══════════════════════════════════════════════════════════════
       EXTERNAL / COMMUNITY PACKAGES (from Bonfort registry)
       Format: <package name="com.org.lib" version="1.0.0" as="alias" />
  ═══════════════════════════════════════════════════════════════ -->
  <packages>
    <!-- <package name="com.nux.json"      version="^1.2"  as="json"  /> -->
    <!-- <package name="com.nux.http"      version="^2.0"  as="http"  /> -->
    <!-- <package name="com.nux.crypto"    version="^1.0"  as="crypto"/> -->
    <!-- <package name="com.nux.database"  version="^3.1"  as="db"    /> -->
    <!-- <package name="com.nux.grpc"      version="^1.0"  as="grpc"  /> -->
  </packages>

  <!-- ═══════════════════════════════════════════════════════════════
       FILE-LEVEL CUSTOM IMPORTS
       Override imports for specific .nux files.
       Each <file> block applies ONLY to the named file.
       If a <file> block exists, nux-libs above are NOT auto-applied
       to that file unless inherit="true" is set.
  ═══════════════════════════════════════════════════════════════ -->
  <file-overrides>
    <!-- Example: main.nux only needs io and string -->
    <!-- <file path="main.nux" inherit="false">
           <import pkg="nux.core.io"     as="io"    />
           <import pkg="nux.core.string" as="string" />
         </file> -->

    <!-- Example: train.nux needs full AI stack -->
    <!-- <file path="training/train.nux" inherit="true">
           <import pkg="nux.ai.tensor"   as="tensor" />
           <import pkg="nux.ai.nn"       as="nn"     />
           <import pkg="nux.ai.optim"    as="optim"  />
           <lang name="python" version="3.13" alias="py">
             <from-import module="numpy" as="np" />
           </lang>
         </file> -->
  </file-overrides>

  <!-- ═══════════════════════════════════════════════════════════════
       COMPILER / OVM SETTINGS
  ═══════════════════════════════════════════════════════════════ -->
  <settings>
    <ovm>
      <timeout-ms>30000</timeout-ms>
      <max-concurrent-langs>8</max-concurrent-langs>
      <default-lang>nux</default-lang>
    </ovm>
    <compiler>
      <target>nxb</target>              <!-- output format: nxb | native | wasm -->
      <optimize>true</optimize>
      <debug>false</debug>
      <simd>auto</simd>                 <!-- auto | avx2 | neon | rvv | off -->
      <gc>generational</gc>             <!-- generational | arena | off -->
      <jit-threshold>100</jit-threshold>
    </compiler>
  </settings>

</nux-imports>
