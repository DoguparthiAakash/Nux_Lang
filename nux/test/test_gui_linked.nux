# Nux Linked Modules Test
# Scenario: Single Library, Multiple Files Linked
# Verifies importing local modules

import "external.gui.gui";
import "modules.gui_helper"; 

class MockFB {
    var width; 
    var height;
    func init(w, h) { this.width = w; this.height = h; }
    func fill_rect(x, y, w, h, c) {}
    func draw_line(x1, y1, x2, y2, c) {}
}

func main() {
    print("Running GUI Modular Test...");
    
    var fb = new MockFB();
    fb.init(800, 600);
    var gui = new Gui();
    gui.init(fb);
    
    var factory = new WindowFactory();
    var win = factory.create_alert_window("Alert", "This is modular!");
    
    gui.add_window(win);
    gui.render();
    
    print("Modular Test Passed.");
}

main();
