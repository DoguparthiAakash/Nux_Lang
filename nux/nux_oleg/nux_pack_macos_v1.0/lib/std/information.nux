# ===== CHANNEL CAPACITY =====

func channel_capacity_bsc(p) {
    # Binary symmetric channel capacity
    # C = 1 - H(p)
    return 1.0 - entropy_shannon([p, 1.0 - p]);
}

func channel_capacity_awgn(snr) {
    # AWGN channel capacity
    # C = (1/2) log2(1 + SNR)
    return 0.5 * log2(1.0 + snr);
}

# ===== SOURCE CODING =====

func source_lempel_ziv(data) {
    # Lempel-Ziv compression
    var dictionary = {};
    var compressed = [];
    var w: string = "";
    var dictSize: int = 256;
    
    # Initialize dictionary
    var i: int = 0;
    while (i < 256) {
        dictionary[str_fromCharCode(i)] = i;
        i = i + 1;
    }
    
    # Compress
    i = 0;
    while (i < length(data)) {
        var c = charAt(data, i);
        var wc = w + c;
        
        if (obj_has(dictionary, wc)) {
            w = wc;
        } else {
            arr_push(compressed, dictionary[w]);
            dictionary[wc] = dictSize;
            dictSize = dictSize + 1;
            w = c;
        }
        
        i = i + 1;
    }
    
    if (w != "") {
        arr_push(compressed, dictionary[w]);
    }
    
    return compressed;
}

