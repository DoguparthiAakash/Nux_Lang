# ===== PROPERTY OPERATIONS =====

func obj_has(obj, key) {
    # Check if object has property
    # TODO: Implement with VM object support
    return false;
}

func obj_get(obj, key, defaultValue) {
    # Get property with default
    if (obj_has(obj, key)) {
        return obj[key];
    }
    return defaultValue;
}

func obj_set(obj, key, value) {
    # Set property
    obj[key] = value;
    return obj;
}

