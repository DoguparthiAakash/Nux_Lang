# Nux Standard Library - Object/Map Operations
# Dictionary and object manipulation

# ===== CREATION =====

func obj_create() {
    # Create empty object
    return {};
}

func obj_fromPairs(pairs) {
    # Create object from array of [key, value] pairs
    var obj = {};
    var i: int = 0;
    
    while (i < arr_length(pairs)) {
        var pair = pairs[i];
        obj[pair[0]] = pair[1];
        i = i + 1;
    }
    
    return obj;
}

