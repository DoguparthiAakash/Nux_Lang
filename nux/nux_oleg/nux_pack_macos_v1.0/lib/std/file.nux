# ===== PATH OPERATIONS =====

func path_join(parts) {
    # Join path components
    return arr_join(parts, "/");
}

func path_basename(path) {
    # Get filename from path
    var parts = str_split(path, "/");
    var len = arr_length(parts);
    if (len > 0) {
        return parts[len - 1];
    }
    return path;
}

func path_dirname(path) {
    # Get directory from path
    var parts = str_split(path, "/");
    var len = arr_length(parts);
    if (len > 1) {
        return arr_join(arr_slice(parts, 0, len - 1), "/");
    }
    return ".";
}

func path_extension(path) {
    # Get file extension
    var basename = path_basename(path);
    var lastDot = str_lastIndexOf(basename, ".");
    if (lastDot != -1) {
        return str_substring(basename, lastDot + 1, str_length(basename));
    }
    return "";
}

# ===== UTILITY =====

func file_readJSON(path) {
    # Read and parse JSON file
    var content = file_read(path);
    return json_parse(content);
}

func file_writeJSON(path, obj) {
    # Write object as JSON file
    var content = json_stringify(obj);
    return file_write(path, content);
}
