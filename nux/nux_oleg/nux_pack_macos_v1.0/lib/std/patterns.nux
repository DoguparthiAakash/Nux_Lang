# Nux Standard Library - Advanced Pattern Matching
# Powerful pattern matching and destructuring

# ===== PATTERN MATCHING =====

func match(value, patterns) {
    # Pattern matching
    var i: int = 0;
    
    while (i < arr_length(patterns)) {
        var pattern = patterns[i];
        var matched = pattern_match(value, pattern.pattern);
        
        if (matched.success) {
            return pattern.handler(matched.bindings);
        }
        
        i = i + 1;
    }
    
    # No match found
    return null;
}

func pattern_match(value, pattern) {
    # Match value against pattern
    if (pattern.type == "literal") {
        return {
            success: value == pattern.value,
            bindings: {}
        };
    }
    
    if (pattern.type == "variable") {
        var bindings = {};
        bindings[pattern.name] = value;
        return {
            success: true,
            bindings: bindings
        };
    }
    
    if (pattern.type == "wildcard") {
        return {
            success: true,
            bindings: {}
        };
    }
    
    if (pattern.type == "array") {
        if (!Array.isArray(value)) {
            return {success: false, bindings: {}};
        }
        
        return pattern_matchArray(value, pattern);
    }
    
    if (pattern.type == "object") {
        return pattern_matchObject(value, pattern);
    }
    
    if (pattern.type == "guard") {
        var innerMatch = pattern_match(value, pattern.pattern);
        if (innerMatch.success && pattern.guard(value)) {
            return innerMatch;
        }
        return {success: false, bindings: {}};
    }
    
    return {success: false, bindings: {}};
}

func pattern_matchArray(value, pattern) {
    # Match array pattern
    var bindings = {};
    
    if (pattern.exact && arr_length(value) != arr_length(pattern.elements)) {
        return {success: false, bindings: {}};
    }
    
    var i: int = 0;
    while (i < arr_length(pattern.elements)) {
        var elemPattern = pattern.elements[i];
        
        if (elemPattern.type == "rest") {
            # Rest pattern captures remaining elements
            bindings[elemPattern.name] = arr_slice(value, i, arr_length(value));
            break;
        }
        
        if (i >= arr_length(value)) {
            return {success: false, bindings: {}};
        }
        
        var elemMatch = pattern_match(value[i], elemPattern);
        if (!elemMatch.success) {
            return {success: false, bindings: {}};
        }
        
        # Merge bindings
        var keys = obj_keys(elemMatch.bindings);
        arr_forEach(keys, func(key) {
            bindings[key] = elemMatch.bindings[key];
        });
        
        i = i + 1;
    }
    
    return {success: true, bindings: bindings};
}

func pattern_matchObject(value, pattern) {
    # Match object pattern
    var bindings = {};
    var keys = obj_keys(pattern.fields);
    
    var i: int = 0;
    while (i < arr_length(keys)) {
        var key = keys[i];
        var fieldPattern = pattern.fields[key];
        
        if (!obj_has(value, key)) {
            return {success: false, bindings: {}};
        }
        
        var fieldMatch = pattern_match(value[key], fieldPattern);
        if (!fieldMatch.success) {
            return {success: false, bindings: {}};
        }
        
        # Merge bindings
        var bindKeys = obj_keys(fieldMatch.bindings);
        arr_forEach(bindKeys, func(bkey) {
            bindings[bkey] = fieldMatch.bindings[bkey];
        });
        
        i = i + 1;
    }
    
    return {success: true, bindings: bindings};
}

# ===== PATTERN CONSTRUCTORS =====

func pat_literal(value) {
    # Literal pattern
    return {type: "literal", value: value};
}

func pat_var(name) {
    # Variable pattern (binds value)
    return {type: "variable", name: name};
}

func pat_wildcard() {
    # Wildcard pattern (matches anything)
    return {type: "wildcard"};
}

func pat_array(...elements) {
    # Array pattern
    return {
        type: "array",
        elements: elements,
        exact: true
    };
}

func pat_arrayRest(name) {
    # Rest pattern for arrays
    return {type: "rest", name: name};
}

func pat_object(fields) {
    # Object pattern
    return {type: "object", fields: fields};
}

func pat_guard(pattern, guard) {
    # Guarded pattern
    return {
        type: "guard",
        pattern: pattern,
        guard: guard
    };
}

func pat_or(...patterns) {
    # Or pattern (matches if any pattern matches)
    return {type: "or", patterns: patterns};
}

func pat_and(...patterns) {
    # And pattern (matches if all patterns match)
    return {type: "and", patterns: patterns};
}

# ===== DESTRUCTURING =====

func destructure_array(arr, pattern) {
    # Destructure array
    var match = pattern_match(arr, pattern);
    return match.bindings;
}

func destructure_object(obj, pattern) {
    # Destructure object
    var match = pattern_match(obj, pattern);
    return match.bindings;
}

# ===== ALGEBRAIC DATA TYPES =====

func adt_define(name, variants) {
    # Define algebraic data type
    return {
        name: name,
        variants: variants
    };
}

func adt_variant(type, name, ...args) {
    # Create ADT variant
    return {
        __type__: type,
        __variant__: name,
        __args__: args
    };
}

func adt_match(value, cases) {
    # Match on ADT
    var variant = value.__variant__;
    
    if (obj_has(cases, variant)) {
        return cases[variant](...value.__args__);
    }
    
    if (obj_has(cases, "_")) {
        return cases["_"](value);
    }
    
    return null;
}

# Example: Option type
func Option_Some(value) {
    return adt_variant("Option", "Some", value);
}

func Option_None() {
    return adt_variant("Option", "None");
}

func option_map(opt, func) {
    return adt_match(opt, {
        Some: func(value) { return Option_Some(func(value)); },
        None: func() { return Option_None(); }
    });
}

# Example: Result type
func Result_Ok(value) {
    return adt_variant("Result", "Ok", value);
}

func Result_Err(error) {
    return adt_variant("Result", "Err", error);
}

func result_map(result, func) {
    return adt_match(result, {
        Ok: func(value) { return Result_Ok(func(value)); },
        Err: func(err) { return Result_Err(err); }
    });
}

# ===== ACTIVE PATTERNS =====

func activePattern_define(name, matcher) {
    # Define active pattern
    return {
        name: name,
        matcher: matcher
    };
}

func activePattern_match(value, pattern) {
    # Match using active pattern
    return pattern.matcher(value);
}

# Example: Even/Odd active pattern
func pattern_EvenOdd() {
    return activePattern_define("EvenOdd", func(n) {
        if (n % 2 == 0) {
            return {matched: true, value: "Even"};
        } else {
            return {matched: true, value: "Odd"};
        }
    });
}

