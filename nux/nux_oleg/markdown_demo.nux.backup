# Nux Markdown Demo

import "nux.markdown";

func main() {
    print("Testing Markdown Parser...");
    
    var md = new MarkdownParser();
    md.init();
    
    var input = "# Hello World\n";
    input = input + "This is a **bold** statement.\n";
    input = input + "\n";
    input = input + "## Features\n";
    input = input + "- Simple\n";
    input = input + "- Fast\n";
    input = input + "- Lightweight\n";
    input = input + "\n";
    input = input + "```\n";
    input = input + "print(\"Code Block\");\n";
    input = input + "```\n";
    
    print("--- Input Markdown ---");
    print(input);
    
    var html = md.parse(input);
    
    print("--- Output HTML ---");
    print(html);
}

main();
