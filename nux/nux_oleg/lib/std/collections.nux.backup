// Enhanced Standard Library - Collections

// ============= VECTOR (DYNAMIC ARRAY) =============

class Vec<T> {
    var data: *T;
    var length: int = 0;
    var capacity: int = 0;
    
    func new() -> Vec<T> {
        return Vec<T> {
            data: null,
            length: 0,
            capacity: 0
        };
    }
    
    func with_capacity(cap: int) -> Vec<T> {
        return Vec<T> {
            data: allocate_array<T>(cap),
            length: 0,
            capacity: cap
        };
    }
    
    func push(value: T) {
        if (this.length == this.capacity) {
            this.grow();
        }
        this.data[this.length] = value;
        this.length += 1;
    }
    
    func pop() -> Option<T> {
        if (this.length == 0) {
            return None;
        }
        this.length -= 1;
        return Some(this.data[this.length]);
    }
    
    func get(index: int) -> Option<&T> {
        if (index < 0 || index >= this.length) {
            return None;
        }
        return Some(&this.data[index]);
    }
    
    func insert(index: int, value: T) {
        if (index < 0 || index > this.length) {
            panic("Index out of bounds");
        }
        
        if (this.length == this.capacity) {
            this.grow();
        }
        
        // Shift elements right
        for (var i = this.length; i > index; i--) {
            this.data[i] = this.data[i - 1];
        }
        
        this.data[index] = value;
        this.length += 1;
    }
    
    func remove(index: int) -> T {
        if (index < 0 || index >= this.length) {
            panic("Index out of bounds");
        }
        
        var value = this.data[index];
        
        // Shift elements left
        for (var i = index; i < this.length - 1; i++) {
            this.data[i] = this.data[i + 1];
        }
        
        this.length -= 1;
        return value;
    }
    
    func clear() {
        this.length = 0;
    }
    
    func reserve(additional: int) {
        var new_cap = this.length + additional;
        if (new_cap > this.capacity) {
            this.resize(new_cap);
        }
    }
    
    func shrink_to_fit() {
        if (this.length < this.capacity) {
            this.resize(this.length);
        }
    }
    
    func iter() -> Iterator<T> {
        return VecIterator<T> {
            vec: this,
            index: 0
        };
    }
    
    func map<U>(f: func(T) -> U) -> Vec<U> {
        var result = Vec<U>.with_capacity(this.length);
        for (var i = 0; i < this.length; i++) {
            result.push(f(this.data[i]));
        }
        return result;
    }
    
    func filter(predicate: func(T) -> bool) -> Vec<T> {
        var result = Vec<T>.new();
        for (var i = 0; i < this.length; i++) {
            if (predicate(this.data[i])) {
                result.push(this.data[i]);
            }
        }
        return result;
    }
    
    func fold<U>(init: U, f: func(U, T) -> U) -> U {
        var acc = init;
        for (var i = 0; i < this.length; i++) {
            acc = f(acc, this.data[i]);
        }
        return acc;
    }
    
    func sort() where T: Ord {
        quick_sort_range(this.data, 0, this.length - 1);
    }
    
    func sort_by(compare: func(T, T) -> int) {
        quick_sort_by(this.data, 0, this.length - 1, compare);
    }
    
    func binary_search(target: T) -> Option<int> where T: Ord {
        var left = 0;
        var right = this.length - 1;
        
        while (left <= right) {
            var mid = left + (right - left) / 2;
            
            if (this.data[mid] == target) {
                return Some(mid);
            } else if (this.data[mid] < target) {
                left = mid + 1;
            } else {
                right = mid - 1;
            }
        }
        
        return None;
    }
    
    func reverse() {
        for (var i = 0; i < this.length / 2; i++) {
            var temp = this.data[i];
            this.data[i] = this.data[this.length - 1 - i];
            this.data[this.length - 1 - i] = temp;
        }
    }
    
    func contains(value: T) -> bool where T: Eq {
        for (var i = 0; i < this.length; i++) {
            if (this.data[i] == value) {
                return true;
            }
        }
        return false;
    }
    
    func dedup() where T: Eq {
        if (this.length <= 1) return;
        
        var write = 1;
        for (var read = 1; read < this.length; read++) {
            if (this.data[read] != this.data[read - 1]) {
                this.data[write] = this.data[read];
                write += 1;
            }
        }
        this.length = write;
    }
    
    private func grow() {
        var new_cap = if (this.capacity == 0) 4 else this.capacity * 2;
        this.resize(new_cap);
    }
    
    private func resize(new_cap: int) {
        var new_data = allocate_array<T>(new_cap);
        
        if (this.data != null) {
            for (var i = 0; i < this.length; i++) {
                new_data[i] = this.data[i];
            }
            deallocate_array(this.data);
        }
        
        this.data = new_data;
        this.capacity = new_cap;
    }
}

// ============= HASHMAP =============

class HashMap<K, V> {
    var buckets: [Vec<(K, V)>];
    var size: int = 0;
    var capacity: int = 16;
    var load_factor: float = 0.75;
    
    func new() -> HashMap<K, V> {
        var buckets: [Vec<(K, V)>] = [];
        for (var i = 0; i < 16; i++) {
            buckets.push(Vec<(K, V)>.new());
        }
        
        return HashMap<K, V> {
            buckets: buckets,
            size: 0,
            capacity: 16
        };
    }
    
    func insert(key: K, value: V) -> Option<V> where K: Hash + Eq {
        if (this.size as float / this.capacity as float > this.load_factor) {
            this.rehash();
        }
        
        var hash = key.hash() % this.capacity;
        var bucket = &mut this.buckets[hash];
        
        // Check if key exists
        for (var i = 0; i < bucket.length; i++) {
            if (bucket.data[i].0 == key) {
                var old = bucket.data[i].1;
                bucket.data[i].1 = value;
                return Some(old);
            }
        }
        
        // Insert new
        bucket.push((key, value));
        this.size += 1;
        return None;
    }
    
    func get(key: K) -> Option<&V> where K: Hash + Eq {
        var hash = key.hash() % this.capacity;
        var bucket = &this.buckets[hash];
        
        for (var i = 0; i < bucket.length; i++) {
            if (bucket.data[i].0 == key) {
                return Some(&bucket.data[i].1);
            }
        }
        
        return None;
    }
    
    func remove(key: K) -> Option<V> where K: Hash + Eq {
        var hash = key.hash() % this.capacity;
        var bucket = &mut this.buckets[hash];
        
        for (var i = 0; i < bucket.length; i++) {
            if (bucket.data[i].0 == key) {
                var value = bucket.remove(i).1;
                this.size -= 1;
                return Some(value);
            }
        }
        
        return None;
    }
    
    func contains_key(key: K) -> bool where K: Hash + Eq {
        return this.get(key).is_some();
    }
    
    func keys() -> Vec<K> {
        var result = Vec<K>.with_capacity(this.size);
        
        for (var bucket in this.buckets) {
            for (var i = 0; i < bucket.length; i++) {
                result.push(bucket.data[i].0);
            }
        }
        
        return result;
    }
    
    func values() -> Vec<V> {
        var result = Vec<V>.with_capacity(this.size);
        
        for (var bucket in this.buckets) {
            for (var i = 0; i < bucket.length; i++) {
                result.push(bucket.data[i].1);
            }
        }
        
        return result;
    }
    
    func iter() -> HashMapIterator<K, V> {
        return HashMapIterator<K, V> {
            map: this,
            bucket_index: 0,
            item_index: 0
        };
    }
    
    private func rehash() {
        var new_capacity = this.capacity * 2;
        var new_buckets: [Vec<(K, V)>] = [];
        
        for (var i = 0; i < new_capacity; i++) {
            new_buckets.push(Vec<(K, V)>.new());
        }
        
        // Rehash all entries
        for (var bucket in this.buckets) {
            for (var i = 0; i < bucket.length; i++) {
                var (key, value) = bucket.data[i];
                var hash = key.hash() % new_capacity;
                new_buckets[hash].push((key, value));
            }
        }
        
        this.buckets = new_buckets;
        this.capacity = new_capacity;
    }
}

// ============= HASHSET =============

class HashSet<T> {
    var map: HashMap<T, ()>;
    
    func new() -> HashSet<T> {
        return HashSet<T> {
            map: HashMap<T, ()>.new()
        };
    }
    
    func insert(value: T) -> bool where T: Hash + Eq {
        return this.map.insert(value, ()).is_none();
    }
    
    func remove(value: T) -> bool where T: Hash + Eq {
        return this.map.remove(value).is_some();
    }
    
    func contains(value: T) -> bool where T: Hash + Eq {
        return this.map.contains_key(value);
    }
    
    func union(other: &HashSet<T>) -> HashSet<T> where T: Hash + Eq {
        var result = HashSet<T>.new();
        
        for (var item in this.iter()) {
            result.insert(item);
        }
        
        for (var item in other.iter()) {
            result.insert(item);
        }
        
        return result;
    }
    
    func intersection(other: &HashSet<T>) -> HashSet<T> where T: Hash + Eq {
        var result = HashSet<T>.new();
        
        for (var item in this.iter()) {
            if (other.contains(item)) {
                result.insert(item);
            }
        }
        
        return result;
    }
    
    func difference(other: &HashSet<T>) -> HashSet<T> where T: Hash + Eq {
        var result = HashSet<T>.new();
        
        for (var item in this.iter()) {
            if (!other.contains(item)) {
                result.insert(item);
            }
        }
        
        return result;
    }
}

