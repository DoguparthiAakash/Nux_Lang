// Enhanced Advanced Type System with Practical Examples

// ============= SMART UNION TYPES =============

// Result type with automatic error propagation
union Result<T, E> {
    Ok(T),
    Err(E)
}

// ? operator for automatic unwrapping
func divide(a: int, b: int) -> Result<int, string> {
    if (b == 0) {
        return Result.Err("Division by zero");
    }
    return Result.Ok(a / b);
}

func complex_calculation() -> Result<int, string> {
    var x = divide(10, 2)?;  // Auto-unwrap or return error
    var y = divide(20, x)?;
    var z = divide(y, 3)?;
    return Result.Ok(z);
}

// ============= ENHANCED PHANTOM TYPES =============

// Type-safe state machines
class Connection<State> {
    var socket: int;
}

type Disconnected = phantom;
type Connected = phantom;
type Authenticated = phantom;

func connect(host: string) -> Connection<Connected> {
    var socket = syscall_connect(host);
    return Connection<Connected> { socket: socket };
}

func authenticate(conn: Connection<Connected>, password: string) -> Connection<Authenticated> {
    syscall_auth(conn.socket, password);
    return Connection<Authenticated> { socket: conn.socket };
}

func send_data(conn: Connection<Authenticated>, data: string) {
    // Can only send on authenticated connection!
    syscall_send(conn.socket, data);
}

// Compile-time state verification
func example_usage() {
    var conn = connect("example.com");
    // send_data(conn, "hello");  // ERROR: not authenticated
    
    var auth_conn = authenticate(conn, "password123");
    send_data(auth_conn, "hello");  // ✓ OK
}

// ============= PRACTICAL DEPENDENT TYPES =============

// Matrix with compile-time dimension checking
class Matrix<const M: int, const N: int> {
    var data: [[float; N]; M];
    
    func new() -> Matrix<M, N> {
        var data: [[float; N]; M] = [];
        for (var i = 0; i < M; i++) {
            var row: [float; N] = Array.filled(N, 0.0);
            data.push(row);
        }
        return Matrix<M, N> { data: data };
    }
    
    func get(i: int, j: int) -> float {
        return this.data[i][j];
    }
    
    func set(i: int, j: int, value: float) {
        this.data[i][j] = value;
    }
    
    // Type-safe matrix multiplication
    func mul<P: int>(other: Matrix<N, P>) -> Matrix<M, P> {
        var result = Matrix<M, P>.new();
        
        for (var i = 0; i < M; i++) {
            for (var j = 0; j < P; j++) {
                var sum = 0.0;
                for (var k = 0; k < N; k++) {
                    sum += this.data[i][k] * other.data[k][j];
                }
                result.data[i][j] = sum;
            }
        }
        
        return result;
    }
    
    // Transpose
    func transpose() -> Matrix<N, M> {
        var result = Matrix<N, M>.new();
        
        for (var i = 0; i < M; i++) {
            for (var j = 0; j < N; j++) {
                result.data[j][i] = this.data[i][j];
            }
        }
        
        return result;
    }
}

// Usage with compile-time checking
func matrix_example() {
    var a = Matrix<2, 3>.new();  // 2x3 matrix
    var b = Matrix<3, 4>.new();  // 3x4 matrix
    
    var c = a.mul(b);  // ✓ OK: (2x3) × (3x4) = (2x4)
    
    // var d = b.mul(a);  // ✗ ERROR: (3x4) × (2x3) incompatible!
}

// ============= REFINEMENT TYPES WITH RUNTIME CHECKS =============

// Positive integers
type Positive = int where x > 0;

func make_positive(x: int) -> Option<Positive> {
    if (x > 0) {
        return Some(x as Positive);
    }
    return None;
}

func sqrt(x: Positive) -> float {
    // Guaranteed positive, no need to check!
    return math_sqrt(x);
}

// Non-empty arrays
type NonEmpty<T> = [T] where length > 0;

func head<T>(arr: NonEmpty<T>) -> T {
    // Guaranteed non-empty!
    return arr[0];
}

func make_non_empty<T>(arr: [T]) -> Option<NonEmpty<T>> {
    if (arr.length > 0) {
        return Some(arr as NonEmpty<T>);
    }
    return None;
}

// Email validation
type Email = string where matches(/^[^@]+@[^@]+\.[^@]+$/);

func send_email(to: Email, subject: string, body: string) {
    // Guaranteed valid email!
    smtp_send(to, subject, body);
}

func validate_email(s: string) -> Option<Email> {
    if (s.matches(/^[^@]+@[^@]+\.[^@]+$/)) {
        return Some(s as Email);
    }
    return None;
}

// ============= ALGEBRAIC EFFECTS IN PRACTICE =============

// Async/await as an effect
effect Async {
    func await<T>(future: Future<T>) -> T;
}

func fetch_user(id: int) -> User with Async {
    var response = perform Async.await(http_get("/users/" + id));
    return JSON.parse<User>(response.body);
}

func fetch_posts(user_id: int) -> [Post] with Async {
    var response = perform Async.await(http_get("/posts?user=" + user_id));
    return JSON.parse<[Post]>(response.body);
}

// Compose async operations
func get_user_with_posts(id: int) -> (User, [Post]) with Async {
    var user = fetch_user(id);
    var posts = fetch_posts(id);
    return (user, posts);
}

// Handle async effect
func run_async<T>(f: func() -> T with Async) -> Future<T> {
    return handle f() {
        Async.await(future) => {
            future.then((value) => resume(value));
        }
    };
}

// ============= LINEAR TYPES FOR RESOURCE SAFETY =============

// File handle that must be closed
linear class File {
    var fd: int;
    
    static func open(path: string) -> File {
        var fd = syscall_open(path);
        return File { fd: fd };
    }
    
    // Consumes self
    func close(self) {
        syscall_close(this.fd);
    }
    
    // Borrows self (doesn't consume)
    func read(&self) -> string {
        return syscall_read(this.fd);
    }
}

func use_file() {
    var file = File.open("test.txt");
    var content = file.read();  // Borrow
    println(content);
    file.close();  // Consume (must be called exactly once)
    // file.read();  // ERROR: use after move
}

// ============= TYPE-LEVEL PROGRAMMING =============

// Type-level natural numbers
type Zero = 0;
type Succ<N> = N + 1;

// Type-level addition
type Add<0, N> = N;
type Add<M, N> = Add<M - 1, Succ<N>>;

// Type-level lists
type Nil = [];
type Cons<H, T> = [H, ...T];

// Type-level list length
type Length<[]> = 0;
type Length<[H, ...T]> = 1 + Length<T>;

// Fixed-size vector
class Vec<T, const N: int> {
    var data: [T; N];
    
    // Concatenate with type-level addition
    func concat<M: int>(other: Vec<T, M>) -> Vec<T, N + M> {
        var result = Vec<T, N + M>.new();
        
        for (var i = 0; i < N; i++) {
            result.data[i] = this.data[i];
        }
        
        for (var i = 0; i < M; i++) {
            result.data[N + i] = other.data[i];
        }
        
        return result;
    }
}

// ============= STRUCTURAL SUBTYPING =============

// Duck typing with type safety
interface Renderable {
    func render() -> string;
}

class Button {
    var text: string;
    
    func render() -> string {
        return "<button>" + this.text + "</button>";
    }
}

class Link {
    var url: string;
    var text: string;
    
    func render() -> string {
        return "<a href=\"" + this.url + "\">" + this.text + "</a>";
    }
}

// Both Button and Link are Renderable (structural)
func render_component(component: Renderable) -> string {
    return component.render();
}

// ============= GRADUAL TYPING IN PRACTICE =============

// Start with dynamic typing
func process_data(data: any) -> any {
    return data.transform().filter().map();
}

// Gradually add types
func process_data_typed(data: [int]) -> [int] {
    return data.filter((x) => x > 0).map((x) => x * 2);
}

// Mixed typing for migration
func process_mixed(data: [int] | any) -> [int] | any {
    if (data is [int]) {
        return process_data_typed(data);
    } else {
        return process_data(data);
    }
}
