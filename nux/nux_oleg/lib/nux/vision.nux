# ===== HISTOGRAM =====

func image_histogram(img) {
    # Calculate histogram
    var hist = arr_fill(256, 0);
    var i: int = 0;
    
    while (i < arr_length(img.data)) {
        var value = floor(img.data[i]);
        hist[value] = hist[value] + 1;
        i = i + 1;
    }
    
    return hist;
}

func image_equalizeHistogram(img) {
    # Histogram equalization
    var hist = image_histogram(img);
    var cdf = [];
    var sum: int = 0;
    var i: int = 0;
    
    # Calculate CDF
    while (i < 256) {
        sum = sum + hist[i];
        arr_push(cdf, sum);
        i = i + 1;
    }
    
    # Normalize
    var total = arr_length(img.data);
    var result = image_create(img.width, img.height, img.channels);
    i = 0;
    
    while (i < arr_length(img.data)) {
        var value = floor(img.data[i]);
        result.data[i] = floor(cdf[value] * 255 / total);
        i = i + 1;
    }
    
    return result;
}

