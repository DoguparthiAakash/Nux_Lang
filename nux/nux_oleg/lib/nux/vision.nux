func image_open(img, kernelSize) {
    # Morphological opening (erosion then dilation)
    var eroded = image_erode(img, kernelSize);
    return image_dilate(eroded, kernelSize);
}

func image_close(img, kernelSize) {
    # Morphological closing (dilation then erosion)
    var dilated = image_dilate(img, kernelSize);
    return image_erode(dilated, kernelSize);
}
