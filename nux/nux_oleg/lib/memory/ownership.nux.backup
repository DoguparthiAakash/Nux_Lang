// Nux Ownership & Borrowing System (Rust-style Memory Safety)

// ============= OWNERSHIP RULES =============

// Rule 1: Each value has exactly one owner
// Rule 2: When owner goes out of scope, value is dropped
// Rule 3: Values can be moved or borrowed

// ============= OWNERSHIP TRACKING =============

class Owned<T> {
    var value: T;
    var moved: bool = false;
    
    func new(value: T) -> Owned<T> {
        return Owned<T> { value: value };
    }
    
    // Move ownership (consumes self)
    func move() -> T {
        if (this.moved) {
            compile_error("Use of moved value");
        }
        this.moved = true;
        return this.value;
    }
    
    // Immutable borrow
    func borrow() -> &T {
        if (this.moved) {
            compile_error("Cannot borrow moved value");
        }
        return &this.value;
    }
    
    // Mutable borrow
    func borrow_mut() -> &mut T {
        if (this.moved) {
            compile_error("Cannot borrow moved value");
        }
        return &mut this.value;
    }
}

// ============= BORROW CHECKER =============

class BorrowChecker {
    var borrows: Map<*any, BorrowState> = Map.new();
    
    func check_borrow(ptr: *any, mutable: bool) -> bool {
        if (!this.borrows.contains(ptr)) {
            this.borrows[ptr] = BorrowState {
                immutable_count: 0,
                mutable_count: 0
            };
        }
        
        var state = this.borrows[ptr];
        
        if (mutable) {
            // Cannot have mutable borrow if any borrows exist
            if (state.immutable_count > 0 || state.mutable_count > 0) {
                return false;
            }
            state.mutable_count += 1;
        } else {
            // Cannot have immutable borrow if mutable borrow exists
            if (state.mutable_count > 0) {
                return false;
            }
            state.immutable_count += 1;
        }
        
        return true;
    }
    
    func release_borrow(ptr: *any, mutable: bool) {
        if (this.borrows.contains(ptr)) {
            var state = this.borrows[ptr];
            
            if (mutable) {
                state.mutable_count -= 1;
            } else {
                state.immutable_count -= 1;
            }
        }
    }
}

struct BorrowState {
    var immutable_count: int;
    var mutable_count: int;
}

// ============= LIFETIMES =============

// Lifetime annotations
class Ref<'a, T> {
    var ptr: &'a T;
    
    func new(value: &'a T) -> Ref<'a, T> {
        return Ref<'a, T> { ptr: value };
    }
    
    func get() -> &'a T {
        return this.ptr;
    }
}

// Lifetime elision rules
func first<'a>(x: &'a [int]) -> &'a int {
    return &x[0];
}

// Multiple lifetimes
func longest<'a>(x: &'a string, y: &'a string) -> &'a string {
    if (x.length > y.length) {
        return x;
    } else {
        return y;
    }
}

// ============= SMART POINTERS WITH OWNERSHIP =============

// Box: Heap allocation with ownership
class Box<T> {
    var ptr: *T;
    
    func new(value: T) -> Box<T> {
        var ptr = allocate<T>();
        *ptr = value;
        return Box<T> { ptr: ptr };
    }
    
    func into_inner(self) -> T {
        var value = *this.ptr;
        deallocate(this.ptr);
        return value;
    }
    
    func drop(self) {
        deallocate(this.ptr);
    }
}

// Rc: Reference counted (single-threaded)
class Rc<T> {
    var ptr: *T;
    var count: *int;
    
    func new(value: T) -> Rc<T> {
        var ptr = allocate<T>();
        *ptr = value;
        
        var count = allocate<int>();
        *count = 1;
        
        return Rc<T> {
            ptr: ptr,
            count: count
        };
    }
    
    func clone() -> Rc<T> {
        *this.count += 1;
        return Rc<T> {
            ptr: this.ptr,
            count: this.count
        };
    }
    
    func drop(self) {
        *this.count -= 1;
        if (*this.count == 0) {
            deallocate(this.ptr);
            deallocate(this.count);
        }
    }
}

// Arc: Atomic reference counted (thread-safe)
class Arc<T> {
    var ptr: *T;
    var count: *atomic<int>;
    
    func new(value: T) -> Arc<T> {
        var ptr = allocate<T>();
        *ptr = value;
        
        var count = allocate<atomic<int>>();
        atomic_store(count, 1);
        
        return Arc<T> {
            ptr: ptr,
            count: count
        };
    }
    
    func clone() -> Arc<T> {
        atomic_fetch_add(this.count, 1);
        return Arc<T> {
            ptr: this.ptr,
            count: this.count
        };
    }
    
    func drop(self) {
        var old = atomic_fetch_sub(this.count, 1);
        if (old == 1) {
            deallocate(this.ptr);
            deallocate(this.count);
        }
    }
}

// ============= INTERIOR MUTABILITY =============

// Cell: Single-threaded interior mutability
class Cell<T> {
    var value: T;
    
    func new(value: T) -> Cell<T> {
        return Cell<T> { value: value };
    }
    
    func get() -> T where T: Copy {
        return this.value;
    }
    
    func set(value: T) {
        this.value = value;
    }
    
    func replace(value: T) -> T {
        var old = this.value;
        this.value = value;
        return old;
    }
}

// RefCell: Runtime borrow checking
class RefCell<T> {
    var value: T;
    var borrow_state: BorrowState;
    
    func new(value: T) -> RefCell<T> {
        return RefCell<T> {
            value: value,
            borrow_state: BorrowState {
                immutable_count: 0,
                mutable_count: 0
            }
        };
    }
    
    func borrow() -> Ref<T> {
        if (this.borrow_state.mutable_count > 0) {
            panic("Already mutably borrowed");
        }
        this.borrow_state.immutable_count += 1;
        return Ref { ptr: &this.value };
    }
    
    func borrow_mut() -> RefMut<T> {
        if (this.borrow_state.immutable_count > 0 || 
            this.borrow_state.mutable_count > 0) {
            panic("Already borrowed");
        }
        this.borrow_state.mutable_count += 1;
        return RefMut { ptr: &mut this.value };
    }
}

// Mutex: Thread-safe interior mutability
class Mutex<T> {
    var value: T;
    var lock: atomic<bool>;
    
    func new(value: T) -> Mutex<T> {
        return Mutex<T> {
            value: value,
            lock: atomic_new(false)
        };
    }
    
    func lock() -> MutexGuard<T> {
        // Spin until we acquire the lock
        while (atomic_compare_exchange(&this.lock, false, true) != false) {
            // Yield to other threads
            thread_yield();
        }
        
        return MutexGuard {
            mutex: this,
            ptr: &mut this.value
        };
    }
}

class MutexGuard<T> {
    var mutex: *Mutex<T>;
    var ptr: &mut T;
    
    func drop(self) {
        atomic_store(&this.mutex.lock, false);
    }
}

// ============= MEMORY SAFETY EXAMPLES =============

func ownership_example() {
    // Ownership transfer
    var s1 = String.from("hello");
    var s2 = s1;  // s1 moved to s2
    // println(s1);  // ERROR: use of moved value
    println(s2);  // OK
    
    // Borrowing
    var s3 = String.from("world");
    print_string(&s3);  // Borrow
    println(s3);  // OK, s3 still valid
}

func print_string(s: &string) {
    println(*s);
}

func borrow_checker_example() {
    var data = vec![1, 2, 3, 4, 5];
    
    var r1 = &data;  // Immutable borrow
    var r2 = &data;  // OK: multiple immutable borrows
    
    println(r1[0] + r2[0]);
    
    // var r3 = &mut data;  // ERROR: cannot borrow as mutable
    
    // After r1 and r2 go out of scope:
    var r3 = &mut data;  // OK
    r3.push(6);
}

func lifetime_example() {
    var string1 = String.from("long string");
    var result;
    
    {
        var string2 = String.from("short");
        result = longest(&string1, &string2);
        println(result);
    }
    
    // println(result);  // ERROR: string2 dropped, result invalid
}

