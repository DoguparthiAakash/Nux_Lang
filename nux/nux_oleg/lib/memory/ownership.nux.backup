}

// Ownership annotations
@move
func take_ownership<T>(value: T) {
    // value is moved here
}

@borrow
func use_reference<T>(value: &T) {
    // value is borrowed
}

@borrow_mut
func modify_reference<T>(value: &mut T) {
    // value is mutably borrowed
}
