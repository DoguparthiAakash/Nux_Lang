# ===== DOMINANT STRATEGIES =====

func game_dominantStrategy(game, player) {
    # Find dominant strategy for player
    var playerIndex = arr_indexOf(game.players, player);
    var strategies = game.strategies[player];
    
    var dominant = arr_find(strategies, func(strategy) {
        # Check if strategy dominates all others
        return arr_every(strategies, func(other) {
            if (strategy == other) {
                return true;
            }
            
            return game_dominates(game, playerIndex, strategy, other);
        });
    });
    
    return dominant;
}

func game_dominates(game, playerIndex, strategy1, strategy2) {
    # Check if strategy1 dominates strategy2
    var profiles = game_allProfiles(game);
    
    return arr_every(profiles, func(profile) {
        if (profile[playerIndex] != strategy2) {
            return true;
        }
        
        var profile1 = arr_clone(profile);
        profile1[playerIndex] = strategy1;
        
        var payoff1 = game_getPayoff(game, profile1)[playerIndex];
        var payoff2 = game_getPayoff(game, profile)[playerIndex];
        
        return payoff1 >= payoff2;
    });
}

# ===== ITERATED ELIMINATION =====

func game_iteratedDominance(game) {
    # Iterated elimination of dominated strategies
    var currentGame = game;
    var changed: bool = true;
    
    while (changed) {
        changed = false;
        
        arr_forEach(currentGame.players, func(player) {
            var playerIndex = arr_indexOf(currentGame.players, player);
            var strategies = currentGame.strategies[player];
            
            var undominated = arr_filter(strategies, func(strategy) {
                # Check if strategy is dominated
                return !arr_some(strategies, func(other) {
                    if (strategy == other) {
                        return false;
                    }
                    
                    return game_strictlyDominates(currentGame, playerIndex, other, strategy);
                });
            });
            
            if (arr_length(undominated) < arr_length(strategies)) {
                currentGame.strategies[player] = undominated;
                changed = true;
            }
        });
    }
    
    return currentGame;
}

func game_strictlyDominates(game, playerIndex, strategy1, strategy2) {
    # Check if strategy1 strictly dominates strategy2
    var profiles = game_allProfiles(game);
    var betterCount: int = 0;
    
    var result = arr_every(profiles, func(profile) {
        if (profile[playerIndex] != strategy2) {
            return true;
        }
        
        var profile1 = arr_clone(profile);
        profile1[playerIndex] = strategy1;
        
        var payoff1 = game_getPayoff(game, profile1)[playerIndex];
        var payoff2 = game_getPayoff(game, profile)[playerIndex];
        
        if (payoff1 > payoff2) {
            betterCount = betterCount + 1;
        }
        
        return payoff1 >= payoff2;
    });
    
    return result && betterCount > 0;
}

# ===== GAME TREE =====

func gametree_create(root) {
    # Create game tree
    return {
        root: root
    };
}

func gametree_node(player, children, payoffs) {
    # Create game tree node
    return {
        player: player,
        children: children || [],
        payoffs: payoffs || null
    };
}

func gametree_minimax(node, maximizing) {
    # Minimax algorithm
    if (node.payoffs != null) {
        return node.payoffs[0];  # Assume 2-player zero-sum
    }
    
    if (maximizing) {
        var maxValue = -Infinity;
        
        arr_forEach(node.children, func(child) {
            var value = gametree_minimax(child, false);
            maxValue = max(maxValue, value);
        });
        
        return maxValue;
    } else {
        var minValue = Infinity;
        
        arr_forEach(node.children, func(child) {
            var value = gametree_minimax(child, true);
            minValue = min(minValue, value);
        });
        
        return minValue;
    }
}

func gametree_alphabeta(node, alpha, beta, maximizing) {
    # Alpha-beta pruning
    if (node.payoffs != null) {
        return node.payoffs[0];
    }
    
    if (maximizing) {
        var maxValue = -Infinity;
        
        var i: int = 0;
        while (i < arr_length(node.children)) {
            var value = gametree_alphabeta(node.children[i], alpha, beta, false);
            maxValue = max(maxValue, value);
            alpha = max(alpha, value);
            
            if (beta <= alpha) {
                break;  # Beta cutoff
            }
            
            i = i + 1;
        }
        
        return maxValue;
    } else {
        var minValue = Infinity;
        
        var i: int = 0;
        while (i < arr_length(node.children)) {
            var value = gametree_alphabeta(node.children[i], alpha, beta, true);
            minValue = min(minValue, value);
            beta = min(beta, value);
            
            if (beta <= alpha) {
                break;  # Alpha cutoff
            }
            
            i = i + 1;
        }
        
        return minValue;
    }
}

# ===== BACKWARD INDUCTION =====

func gametree_backwardInduction(node) {
    # Backward induction for perfect information games
    if (node.payoffs != null) {
        return {
            strategy: null,
            payoffs: node.payoffs
        };
    }
    
    var bestChild = null;
    var bestPayoff = -Infinity;
    
    arr_forEach(node.children, func(child) {
        var result = gametree_backwardInduction(child);
        var payoff = result.payoffs[node.player];
        
        if (payoff > bestPayoff) {
            bestPayoff = payoff;
            bestChild = child;
        }
    });
    
    return {
        strategy: bestChild,
        payoffs: gametree_backwardInduction(bestChild).payoffs
    };
}

