# ===== EVOLUTIONARY GAME THEORY =====

func evolutionary_replicator(game, population, generations) {
    # Replicator dynamics
    var currentPop = arr_clone(population);
    
    var gen: int = 0;
    while (gen < generations) {
        var fitness = arr_map(currentPop, func(strategy, i) {
            return evolutionary_fitness(game, strategy, currentPop);
        });
        
        var avgFitness = arr_sum(fitness) / arr_length(fitness);
        
        # Update population
        currentPop = arr_map(currentPop, func(strategy, i) {
            return strategy * fitness[i] / avgFitness;
        });
        
        gen = gen + 1;
    }
    
    return currentPop;
}

