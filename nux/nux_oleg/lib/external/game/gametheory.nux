# Nux Standard Library - Game Theory
# Nash equilibrium, game trees, and strategic games

# ===== GAME DEFINITION =====

func game_create(players, strategies, payoffs) {
    # Create strategic game
    return {
        players: players,
        strategies: strategies,  # Map: player -> [strategies]
        payoffs: payoffs  # Map: strategy profile -> [payoffs]
    };
}

func game_getPayoff(game, profile) {
    # Get payoff for strategy profile
    var key = arr_join(profile, ",");
    return game.payoffs[key] || arr_fill(arr_length(game.players), 0);
}

# ===== NASH EQUILIBRIUM =====

func nash_findPure(game) {
    # Find pure strategy Nash equilibria
    var equilibria = [];
    
    # Generate all strategy profiles
    var profiles = game_allProfiles(game);
    
    arr_forEach(profiles, func(profile) {
        if (nash_isPureEquilibrium(game, profile)) {
            arr_push(equilibria, profile);
        }
    });
    
    return equilibria;
}

func nash_isPureEquilibrium(game, profile) {
    # Check if profile is Nash equilibrium
    var payoffs = game_getPayoff(game, profile);
    
    var i: int = 0;
    while (i < arr_length(game.players)) {
        var player = game.players[i];
        var currentStrategy = profile[i];
        var currentPayoff = payoffs[i];
        
        # Check if player can improve by deviating
        var strategies = game.strategies[player];
        
        var canImprove = arr_some(strategies, func(altStrategy) {
            if (altStrategy == currentStrategy) {
                return false;
            }
            
            var altProfile = arr_clone(profile);
            altProfile[i] = altStrategy;
            var altPayoffs = game_getPayoff(game, altProfile);
            
            return altPayoffs[i] > currentPayoff;
        });
        
        if (canImprove) {
            return false;
        }
        
        i = i + 1;
    }
    
    return true;
}

func game_allProfiles(game) {
    # Generate all strategy profiles
    var profiles = [[]];
    
    arr_forEach(game.players, func(player) {
        var newProfiles = [];
        var strategies = game.strategies[player];
        
        arr_forEach(profiles, func(profile) {
            arr_forEach(strategies, func(strategy) {
                var newProfile = arr_clone(profile);
                arr_push(newProfile, strategy);
                arr_push(newProfiles, newProfile);
            });
        });
        
        profiles = newProfiles;
    });
    
    return profiles;
}

