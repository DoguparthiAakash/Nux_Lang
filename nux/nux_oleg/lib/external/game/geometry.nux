# ===== TOPOLOGICAL SPACE =====

func topology_create(points, openSets) {
    # Create topological space
    return {
        points: points,
        openSets: openSets
    };
}

func topology_isOpen(topology, set) {
    # Check if set is open
    return arr_some(topology.openSets, func(openSet) {
        return set_equal(openSet, set);
    });
}

func topology_isClosed(topology, set) {
    # Check if set is closed
    var complement = set_difference(topology.points, set);
    return topology_isOpen(topology, complement);
}

func topology_closure(topology, set) {
    # Closure of set
    var closure = set_clone(set);
    
    # Add limit points
    arr_forEach(topology.points, func(point) {
        if (topology_isLimitPoint(topology, set, point)) {
            set_add(closure, point);
        }
    });
    
    return closure;
}

func topology_isLimitPoint(topology, set, point) {
    # Check if point is limit point
    return arr_every(topology.openSets, func(openSet) {
        if (set_has(openSet, point)) {
            var intersection = set_intersection(openSet, set);
            return set_size(intersection) > 1 || 
                   (set_size(intersection) == 1 && !set_has(intersection, point));
        }
        return true;
    });
}

