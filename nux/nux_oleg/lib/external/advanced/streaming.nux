# Nux Standard Library - Stream Processing
# High-performance data stream processing and ETL

# ===== STREAM =====

func stream_create(source) {
    # Create stream
    return {
        source: source,
        operations: []
    };
}

func stream_of(...values) {
    # Create stream from values
    return stream_create(values);
}

func stream_range(start, end) {
    # Create stream from range
    var values = [];
    var i = start;
    
    while (i < end) {
        arr_push(values, i);
        i = i + 1;
    }
    
    return stream_create(values);
}

func stream_generate(generator, count) {
    # Generate stream
    var values = [];
    var i: int = 0;
    
    while (i < count) {
        arr_push(values, generator(i));
        i = i + 1;
    }
    
    return stream_create(values);
}

# ===== TRANSFORMATION OPERATIONS =====

func stream_map(stream, func) {
    # Map transformation
    arr_push(stream.operations, {
        type: "map",
        func: func
    });
    return stream;
}

func stream_filter(stream, predicate) {
    # Filter operation
    arr_push(stream.operations, {
        type: "filter",
        func: predicate
    });
    return stream;
}

func stream_flatMap(stream, func) {
    # Flat map operation
    arr_push(stream.operations, {
        type: "flatMap",
        func: func
    });
    return stream;
}

func stream_distinct(stream) {
    # Remove duplicates
    arr_push(stream.operations, {
        type: "distinct"
    });
    return stream;
}

func stream_sorted(stream, comparator) {
    # Sort stream
    arr_push(stream.operations, {
        type: "sorted",
        func: comparator
    });
    return stream;
}

# ===== AGGREGATION OPERATIONS =====

func stream_reduce(stream, reducer, initial) {
    # Reduce stream
    var data = stream_execute(stream);
    return arr_reduce(data, reducer, initial);
}

func stream_count(stream) {
    # Count elements
    var data = stream_execute(stream);
    return arr_length(data);
}

func stream_sum(stream) {
    # Sum elements
    return stream_reduce(stream, func(acc, x) { return acc + x; }, 0);
}

func stream_average(stream) {
    # Average elements
    var data = stream_execute(stream);
    return arr_sum(data) / arr_length(data);
}

func stream_min(stream) {
    # Minimum element
    var data = stream_execute(stream);
    return arr_min(data);
}

func stream_max(stream) {
    # Maximum element
    var data = stream_execute(stream);
    return arr_max(data);
}

# ===== COLLECTION OPERATIONS =====

func stream_toArray(stream) {
    # Collect to array
    return stream_execute(stream);
}

func stream_toSet(stream) {
    # Collect to set
    var data = stream_execute(stream);
    var set = set_create();
    
    arr_forEach(data, func(item) {
        set_add(set, item);
    });
    
    return set;
}

func stream_groupBy(stream, keyFn) {
    # Group by key
    var data = stream_execute(stream);
    return groupBy(data, keyFn);
}

func stream_partition(stream, predicate) {
    # Partition stream
    var data = stream_execute(stream);
    return partition(data, predicate);
}

# ===== EXECUTION =====

func stream_execute(stream) {
    # Execute stream pipeline
    var data = stream.source;
    
    # Apply operations
    arr_forEach(stream.operations, func(op) {
        if (op.type == "map") {
            data = arr_map(data, op.func);
        } else if (op.type == "filter") {
            data = arr_filter(data, op.func);
        } else if (op.type == "flatMap") {
            data = arr_flatMap(data, op.func);
        } else if (op.type == "distinct") {
            data = arr_unique(data);
        } else if (op.type == "sorted") {
            data = arr_sort(data, op.func);
        }
    });
    
    return data;
}

# ===== PARALLEL STREAM =====

func parallelStream_create(source, numThreads) {
    # Create parallel stream
    return {
        source: source,
        operations: [],
        numThreads: numThreads || 4,
        parallel: true
    };
}

func parallelStream_execute(stream) {
    # Execute in parallel
    var chunkSize = ceil(arr_length(stream.source) / stream.numThreads);
    var chunks = chunk(stream.source, chunkSize);
    
    # Process chunks in parallel
    var results = arr_map_parallel(chunks, func(chunk) {
        var data = chunk;
        
        arr_forEach(stream.operations, func(op) {
            if (op.type == "map") {
                data = arr_map(data, op.func);
            } else if (op.type == "filter") {
                data = arr_filter(data, op.func);
            }
        });
        
        return data;
    });
    
    # Merge results
    return arr_flatten(results);
}

# ===== WINDOWING =====

func stream_window(stream, size, slide) {
    # Sliding window
    arr_push(stream.operations, {
        type: "window",
        size: size,
        slide: slide || size
    });
    return stream;
}

func stream_tumbling(stream, size) {
    # Tumbling window
    return stream_window(stream, size, size);
}

func stream_sliding(stream, size, slide) {
    # Sliding window
    return stream_window(stream, size, slide);
}

# ===== TIME-BASED OPERATIONS =====

func stream_buffer(stream, duration) {
    # Buffer for duration
    arr_push(stream.operations, {
        type: "buffer",
        duration: duration
    });
    return stream;
}

func stream_sample(stream, interval) {
    # Sample at interval
    arr_push(stream.operations, {
        type: "sample",
        interval: interval
    });
    return stream;
}

# ===== ETL OPERATIONS =====

func etl_extract(source, format) {
    # Extract data
    if (format == "csv") {
        return csv_parse(source);
    } else if (format == "json") {
        return json_parse(source);
    } else if (format == "xml") {
        return xml_parse(source);
    }
    
    return source;
}

func etl_transform(data, transformations) {
    # Transform data
    var stream = stream_create(data);
    
    arr_forEach(transformations, func(transform) {
        if (transform.type == "map") {
            stream = stream_map(stream, transform.func);
        } else if (transform.type == "filter") {
            stream = stream_filter(stream, transform.func);
        } else if (transform.type == "aggregate") {
            stream = stream_groupBy(stream, transform.keyFn);
        }
    });
    
    return stream_toArray(stream);
}

func etl_load(data, destination, format) {
    # Load data
    if (format == "csv") {
        return csv_stringify(data);
    } else if (format == "json") {
        return json_stringify(data);
    } else if (format == "database") {
        # Insert into database
        return db_insertBatch(destination, data);
    }
    
    return data;
}

func etl_pipeline(config) {
    # Complete ETL pipeline
    var data = etl_extract(config.source, config.sourceFormat);
    data = etl_transform(data, config.transformations);
    return etl_load(data, config.destination, config.destFormat);
}

# ===== DATA VALIDATION =====

func validate_schema(data, schema) {
    # Validate data against schema
    var errors = [];
    
    arr_forEach(data, func(item) {
        var keys = obj_keys(schema);
        
        arr_forEach(keys, func(key) {
            var rule = schema[key];
            
            if (rule.required && !obj_has(item, key)) {
                arr_push(errors, "Missing required field: " + key);
            }
            
            if (obj_has(item, key) && rule.type) {
                var actualType = typeof(item[key]);
                if (actualType != rule.type) {
                    arr_push(errors, "Type mismatch for " + key);
                }
            }
        });
    });
    
    return {
        valid: arr_length(errors) == 0,
        errors: errors
    };
}

# ===== DATA QUALITY =====

func quality_checkCompleteness(data, requiredFields) {
    # Check data completeness
    var complete: int = 0;
    var total = arr_length(data);
    
    arr_forEach(data, func(item) {
        var hasAll = arr_every(requiredFields, func(field) {
            return obj_has(item, field) && item[field] != null;
        });
        
        if (hasAll) {
            complete = complete + 1;
        }
    });
    
    return complete / total;
}

func quality_checkUniqueness(data, keyField) {
    # Check uniqueness
    var seen = set_create();
    var duplicates: int = 0;
    
    arr_forEach(data, func(item) {
        var key = item[keyField];
        
        if (set_has(seen, key)) {
            duplicates = duplicates + 1;
        } else {
            set_add(seen, key);
        }
    });
    
    return 1 - (duplicates / arr_length(data));
}

func quality_checkConsistency(data, rules) {
    # Check data consistency
    var violations: int = 0;
    
    arr_forEach(data, func(item) {
        arr_forEach(rules, func(rule) {
            if (!rule.check(item)) {
                violations = violations + 1;
            }
        });
    });
    
    return 1 - (violations / (arr_length(data) * arr_length(rules)));
}
