# Nux SQL Library
# Lightweight, file-based SQL database engine.

import "nux.json";
import "nux.file";
import "nux.string";
import "nux.collections";

# ============================================================
# UTILITIES
# ============================================================

func string_split(str, delimiter) {
    # Simple split implementation if not in std.string
    var parts = new List();
    parts.init();
    
    var current: string = "";
    var i: int = 0;
    for (i = 0; i < str.length(); i = i + 1) {
        # char access syntax? substring?
        var char = str.substring(i, 1); 
        if (char == delimiter) {
            parts.append(current);
            current = "";
        } else {
            current = current + char;
        }
    }
    parts.append(current);
    return parts;
}

func string_trim(str) {
    # Trim whitespace
    # Assuming simple implementation or std.string has it
    return str; 
}

# ============================================================
# CORE CLASSES
# ============================================================

class ResultSet {
    var rows;
    var current_index;
    
    func init(data_rows) {
        this.rows = data_rows;
        this.current_index = -1;
    }
    
    func next() {
        this.current_index = this.current_index + 1;
        if (this.current_index < this.rows.length()) {
            return 1;
        }
        return 0;
    }
    
    func get_row() {
        return this.rows.get(this.current_index);
    }
    
    func get(column) {
        var row = this.rows.get(this.current_index);
        # row is a Dictionary/Map from JSON
        # json_get(row, column) - but if row is Map, use .get()
        # std.json returns VM objects which are likely Maps.
        # But wait, `json_parse` returns an opaque object handle?
        # Nux docs say std.collections Map is a wrapper?
        # Let's assume json_parse returns a Map-compatible object or dict.
        
        # If std.json returns a raw VM object, we might need json_get
        # But var's simplify and assume intrinsics handle field access
        return json_get(row, column);
    }
}

class Connection {
    var db_name;
    var tables;
    
    func init(name) {
        this.db_name = name;
        this.tables = new Map();
        this.tables.init();
    }
    
    func execute(sql) {
        # 1. Tokenize (primitive)
        var tokens = string_split(sql, " ");
        if (tokens.length() == 0) { return 0; }
        
        var command = tokens.get(0);
        
        # 2. Parse & Execute
        if (command == "CREATE") {
            return this.handle_create(tokens);
        }
        if (command == "INSERT") {
            return this.handle_insert(tokens, sql);
        }
        if (command == "SELECT") {
            return this.handle_select(tokens, sql);
        }
        
        return 0;
    }
    
    func handle_create(tokens) {
        # CREATE TABLE users ...
        if (tokens.get(1) == "TABLE") {
            var table_name = tokens.get(2);
            var filename = this.db_name + "_" + table_name + ".ndb";
            
            # Create empty file
            var f = fopen(filename, "w");
            fclose(f);
            
            return 1;
        }
        return 0;
    }
    
    func handle_insert(tokens, full_sql) {
        # INSERT INTO users VALUES ({json})
        # Simplified: expecting JSON object in values for now to avoid full SQL parser
        # INSERT INTO users VALUES {"id":1, "name":"Alice"}
        
        if (tokens.get(1) == "INTO") {
            var table_name = tokens.get(2);
            
            # Find start of JSON
            var val_idx: int = 0; # string index
            # ... Search for '{' in full_sql
            
            # Hack: assume tokens
            # INSERT INTO users VALUES ...
            # 0      1    2     3
            
            var json_start: int = 0;
            # Find '{'
            var i: int = 0;
            for (i = 0; i < full_sql.length(); i = i + 1) {
                if (full_sql.substring(i, 1) == "{") {
                    json_start = i;
                    break;
                }
            }
            
            if (json_start > 0) {
                var json_str = full_sql.substring(json_start, full_sql.length() - json_start);
                
                # Verify JSON is valid?
                # var obj = json_parse(json_str);
                
                # Append to file
                var filename = this.db_name + "_" + table_name + ".ndb";
                var f = fopen(filename, "a");
                fwrite(f, json_str + "\n");
                fclose(f);
                return 1;
            }
        }
        return 0;
    }
    
    func handle_select(tokens, full_sql) {
        # SELECT * FROM users
        # SELECT * FROM users WHERE id=1
        
        var table_name: string = "";
        var where_clause: int = 0;
        var where_col: string = "";
        var where_val: string = "";
        
        var i: int = 1;
        while (i < tokens.length()) {
            if (tokens.get(i) == "FROM") {
                table_name = tokens.get(i + 1);
            }
            if (tokens.get(i) == "WHERE") {
                where_clause = 1;
                # Assume: col=val (no spaces)
                # WHERE id=1
                var cond = tokens.get(i + 1);
                var parts = string_split(cond, "=");
                where_col = parts.get(0);
                where_val = parts.get(1);
            }
            i = i + 1;
        }
        
        var filename = this.db_name + "_" + table_name + ".ndb";
        var f = fopen(filename, "r");
        
        # Read all lines
        var content = fread(f); # Assumes fread reads all? usually
        fclose(f);
        
        var lines = string_split(content, "\n");
        var results = new List();
        results.init();
        
        var j: int = 0;
        for (j = 0; j < lines.length(); j = j + 1) {
            var line = lines.get(j);
            if (line.length() > 2) { # Valid JSON
                var row = json_parse(line);
                
                if (where_clause) {
                    var val = json_get(row, where_col);
                    # Need type conversion? string vs int comparisons
                    # For now exact match stringified
                    if (val == where_val) { # Loose comparison
                         results.append(row);
                    }
                } else {
                    results.append(row);
                }
            }
        }
        
        var rs = new ResultSet();
        rs.init(results);
        return rs;
    }
}
