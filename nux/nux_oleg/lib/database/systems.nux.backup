// Database Systems - SQL and NoSQL implementations

// ============= SQL DATABASE =============

class SQLDatabase {
    var connection: DBConnection;
    
    func connect(host: string, port: int, database: string, user: string, password: string) {
        this.connection = DBConnection.new(host, port, database, user, password);
    }
    
    func query(sql: string) -> ResultSet {
        return this.connection.execute(sql);
    }
    
    func execute(sql: string) -> int {
        return this.connection.execute_update(sql);
    }
    
    func prepare(sql: string) -> PreparedStatement {
        return this.connection.prepare(sql);
    }
    
    func begin_transaction() {
        this.execute("BEGIN TRANSACTION");
    }
    
    func commit() {
        this.execute("COMMIT");
    }
    
    func rollback() {
        this.execute("ROLLBACK");
    }
}

// Query Builder
class QueryBuilder {
    var table: string;
    var select_cols: [string] = ["*"];
    var where_clauses: [string] = [];
    var order_by: Option<string> = None;
    var limit_val: Option<int> = None;
    
    static func table(name: string) -> QueryBuilder {
        return QueryBuilder { table: name };
    }
    
    func select(columns: [string]) -> QueryBuilder {
        this.select_cols = columns;
        return this;
    }
    
    func where(column: string, operator: string, value: any) -> QueryBuilder {
        this.where_clauses.push(column + " " + operator + " " + value.to_string());
        return this;
    }
    
    func order_by(column: string, direction: string = "ASC") -> QueryBuilder {
        this.order_by = Some(column + " " + direction);
        return this;
    }
    
    func limit(n: int) -> QueryBuilder {
        this.limit_val = Some(n);
        return this;
    }
    
    func build() -> string {
        var sql = "SELECT " + this.select_cols.join(", ") + " FROM " + this.table;
        
        if (this.where_clauses.length > 0) {
            sql += " WHERE " + this.where_clauses.join(" AND ");
        }
        
        if (this.order_by != None) {
            sql += " ORDER BY " + this.order_by.unwrap();
        }
        
        if (this.limit_val != None) {
            sql += " LIMIT " + this.limit_val.unwrap().to_string();
        }
        
        return sql;
    }
}

// ORM (Object-Relational Mapping)
class Model {
    var table_name: string;
    var fields: Map<string, any> = Map.new();
    
    func save() {
        var columns: [string] = [];
        var values: [string] = [];
        
        for (var (key, value) in this.fields) {
            columns.push(key);
            values.push("'" + value.to_string() + "'");
        }
        
        var sql = "INSERT INTO " + this.table_name + " (";
        sql += columns.join(", ") + ") VALUES (";
        sql += values.join(", ") + ")";
        
        db.execute(sql);
    }
    
    func update() {
        var sets: [string] = [];
        
        for (var (key, value) in this.fields) {
            if (key != "id") {
                sets.push(key + " = '" + value.to_string() + "'");
            }
        }
        
        var sql = "UPDATE " + this.table_name + " SET ";
        sql += sets.join(", ");
        sql += " WHERE id = " + this.fields["id"].to_string();
        
        db.execute(sql);
    }
    
    func delete() {
        var sql = "DELETE FROM " + this.table_name;
        sql += " WHERE id = " + this.fields["id"].to_string();
        
        db.execute(sql);
    }
    
    static func find(id: int) -> Option<Model> {
        var sql = "SELECT * FROM " + this.table_name + " WHERE id = " + id.to_string();
        var result = db.query(sql);
        
        if (result.has_next()) {
            return Some(Model.from_row(result.next()));
        }
        
        return None;
    }
    
    static func all() -> [Model] {
        var sql = "SELECT * FROM " + this.table_name;
        var result = db.query(sql);
        
        var models: [Model] = [];
        while (result.has_next()) {
            models.push(Model.from_row(result.next()));
        }
        
        return models;
    }
}

// ============= NoSQL DATABASE =============

// Key-Value Store
class KeyValueStore {
    var data: Map<string, string> = Map.new();
    var file_path: string;
    
    func new(file_path: string) -> KeyValueStore {
        var store = KeyValueStore { file_path: file_path };
        store.load();
        return store;
    }
    
    func set(key: string, value: string) {
        this.data[key] = value;
        this.persist();
    }
    
    func get(key: string) -> Option<string> {
        return this.data.get(key);
    }
    
    func delete(key: string) {
        this.data.remove(key);
        this.persist();
    }
    
    func persist() {
        var json = JSON.stringify(this.data);
        File.write(this.file_path, json);
    }
    
    func load() {
        if (File.exists(this.file_path)) {
            var json = File.read(this.file_path);
            this.data = JSON.parse<Map<string, string>>(json);
        }
    }
}

// Document Store
class DocumentStore {
    var collections: Map<string, [Document]> = Map.new();
    
    func collection(name: string) -> Collection {
        if (!this.collections.contains(name)) {
            this.collections[name] = [];
        }
        
        return Collection {
            name: name,
            documents: this.collections[name]
        };
    }
}

class Collection {
    var name: string;
    var documents: [Document];
    
    func insert(doc: Document) {
        doc.id = generate_id();
        this.documents.push(doc);
    }
    
    func find(query: Map<string, any>) -> [Document] {
        return this.documents.filter((doc) => {
            for (var (key, value) in query) {
                if (doc.data[key] != value) {
                    return false;
                }
            }
            return true;
        });
    }
    
    func find_one(query: Map<string, any>) -> Option<Document> {
        var results = this.find(query);
        if (results.length > 0) {
            return Some(results[0]);
        }
        return None;
    }
    
    func update(query: Map<string, any>, update: Map<string, any>) {
        var docs = this.find(query);
        
        for (var doc in docs) {
            for (var (key, value) in update) {
                doc.data[key] = value;
            }
        }
    }
    
    func delete(query: Map<string, any>) {
        this.documents = this.documents.filter((doc) => {
            for (var (key, value) in query) {
                if (doc.data[key] == value) {
                    return false;
                }
            }
            return true;
        });
    }
}

class Document {
    var id: string;
    var data: Map<string, any>;
}

// ============= CACHING =============

// LRU Cache
class LRUCache<K, V> where K: Hash + Eq {
    var capacity: int;
    var cache: Map<K, (V, int)> = Map.new();
    var access_count: int = 0;
    
    func new(capacity: int) -> LRUCache<K, V> {
        return LRUCache<K, V> { capacity: capacity };
    }
    
    func get(key: K) -> Option<V> {
        if (this.cache.contains(key)) {
            var (value, _) = this.cache[key];
            this.cache[key] = (value, this.access_count);
            this.access_count += 1;
            return Some(value);
        }
        
        return None;
    }
    
    func put(key: K, value: V) {
        if (this.cache.size >= this.capacity) {
            this.evict_lru();
        }
        
        this.cache[key] = (value, this.access_count);
        this.access_count += 1;
    }
    
    func evict_lru() {
        var lru_key: Option<K> = None;
        var lru_time = this.access_count;
        
        for (var (key, (_, time)) in this.cache) {
            if (time < lru_time) {
                lru_time = time;
                lru_key = Some(key);
            }
        }
        
        if (lru_key != None) {
            this.cache.remove(lru_key.unwrap());
        }
    }
}

// Redis Client
class RedisClient {
    var socket: TCPSocket;
    
    func connect(host: string, port: int = 6379) {
        this.socket = TCPSocket.connect(host, port);
    }
    
    func set(key: string, value: string) {
        var command = "*3\r\n$3\r\nSET\r\n$" + key.length + "\r\n" + key + "\r\n";
        command += "$" + value.length + "\r\n" + value + "\r\n";
        
        this.socket.send(command.bytes());
        this.read_response();
    }
    
    func get(key: string) -> Option<string> {
        var command = "*2\r\n$3\r\nGET\r\n$" + key.length + "\r\n" + key + "\r\n";
        
        this.socket.send(command.bytes());
        return this.read_response();
    }
}
