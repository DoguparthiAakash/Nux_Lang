// HTTP Client Library

// ============= HTTP REQUEST =============

class HttpRequest {
    var method: string;
    var url: string;
    var headers: [[string; 2]];
    var body: string;
    
    func new(method: string, url: string) -> HttpRequest {
        return HttpRequest {
            method: method,
            url: url,
            headers: [],
            body: ""
        };
    }
    
    func header(key: string, value: string) -> HttpRequest {
        this.headers.push([key, value]);
        return this;
    }
    
    func body(data: string) -> HttpRequest {
        this.body = data;
        return this;
    }
    
    func send() -> HttpResponse {
        // Parse URL
        var parts = this.parse_url(this.url);
        var host = parts[0];
        var port = json_parse_int(parts[1]);
        var path = parts[2];
        
        // Connect to server
        var socket = syscall_connect(host, port);
        
        // Build request
        var request = this.method + " " + path + " HTTP/1.1\r\n";
        request += "Host: " + host + "\r\n";
        
        for (var header in this.headers) {
            request += header[0] + ": " + header[1] + "\r\n";
        }
        
        if (this.body.len() > 0) {
            request += "Content-Length: " + json_stringify_int(this.body.len()) + "\r\n";
        }
        
        request += "\r\n";
        request += this.body;
        
        // Send request
        syscall_send(socket, request);
        
        // Receive response
        var response_data = "";
        while (true) {
            var chunk = syscall_recv(socket, 4096);
            if (chunk.len() == 0) {
                break;
            }
            response_data += chunk;
        }
        
        syscall_close(socket);
        
        return this.parse_response(response_data);
    }
    
    func parse_url(url: string) -> [string] {
        // Simple URL parsing: http://host:port/path
        var result: [string] = ["", "80", "/"];
        
        var start = 0;
        if (str_starts_with(url, "http://")) {
            start = 7;
        } else if (str_starts_with(url, "https://")) {
            start = 8;
            result[1] = "443";
        }
        
        var host_end = start;
        while (host_end < url.len() && url[host_end] != ':' && url[host_end] != '/') {
            host_end++;
        }
        
        result[0] = str_substring(url, start, host_end);
        
        if (host_end < url.len() && url[host_end] == ':') {
            var port_start = host_end + 1;
            var port_end = port_start;
            while (port_end < url.len() && url[port_end] != '/') {
                port_end++;
            }
            result[1] = str_substring(url, port_start, port_end);
            host_end = port_end;
        }
        
        if (host_end < url.len()) {
            result[2] = str_substring(url, host_end, url.len());
        }
        
        return result;
    }
    
    func parse_response(data: string) -> HttpResponse {
        var lines = str_split(data, "\r\n");
        
        // Parse status line
        var status_parts = str_split(lines[0], " ");
        var status_code = json_parse_int(status_parts[1]);
        
        // Parse headers
        var headers: [[string; 2]] = [];
        var i = 1;
        
        while (i < lines.len() && lines[i].len() > 0) {
            var colon_pos = str_find(lines[i], ":");
            if (colon_pos >= 0) {
                var key = str_substring(lines[i], 0, colon_pos);
                var value = str_trim(str_substring(lines[i], colon_pos + 1, lines[i].len()));
                headers.push([key, value]);
            }
            i++;
        }
        
        // Parse body
        var body = "";
        i++;  // Skip empty line
        while (i < lines.len()) {
            body += lines[i];
            if (i < lines.len() - 1) {
                body += "\r\n";
            }
            i++;
        }
        
        return HttpResponse {
            status_code: status_code,
            headers: headers,
            body: body
        };
    }
}

class HttpResponse {
    var status_code: int;
    var headers: [[string; 2]];
    var body: string;
    
    func get_header(key: string) -> string {
        for (var header in this.headers) {
            if (str_to_lowercase(header[0]) == str_to_lowercase(key)) {
                return header[1];
            }
        }
        return "";
    }
    
    func is_success() -> bool {
        return this.status_code >= 200 && this.status_code < 300;
    }
}

// ============= HTTP CLIENT =============

class HttpClient {
    var base_url: string;
    var default_headers: [[string; 2]];
    
    func new() -> HttpClient {
        return HttpClient {
            base_url: "",
            default_headers: []
        };
    }
    
    func get(url: string) -> HttpResponse {
        var request = HttpRequest.new("GET", this.resolve_url(url));
        this.apply_default_headers(request);
        return request.send();
    }
    
    func post(url: string, body: string) -> HttpResponse {
        var request = HttpRequest.new("POST", this.resolve_url(url));
        this.apply_default_headers(request);
        request.body(body);
        return request.send();
    }
    
    func put(url: string, body: string) -> HttpResponse {
        var request = HttpRequest.new("PUT", this.resolve_url(url));
        this.apply_default_headers(request);
        request.body(body);
        return request.send();
    }
    
    func delete(url: string) -> HttpResponse {
        var request = HttpRequest.new("DELETE", this.resolve_url(url));
        this.apply_default_headers(request);
        return request.send();
    }
    
    func resolve_url(url: string) -> string {
        if (str_starts_with(url, "http://") || str_starts_with(url, "https://")) {
            return url;
        }
        return this.base_url + url;
    }
    
    func apply_default_headers(request: HttpRequest) {
        for (var header in this.default_headers) {
            request.header(header[0], header[1]);
        }
    }
}

// ============= EXAMPLE USAGE =============

func http_example() {
    // Simple GET request
    var response = HttpRequest.new("GET", "http://example.com/api/users")
        .header("Accept", "application/json")
        .send();
    
    println("Status: " + json_stringify_int(response.status_code));
    println("Body: " + response.body);
    
    // Using client
    var client = HttpClient.new();
    client.base_url = "http://api.example.com";
    client.default_headers.push(["Authorization", "Bearer token123"]);
    
    var users = client.get("/users");
    println("Users: " + users.body);
    
    var new_user = client.post("/users", "{\"name\":\"Alice\"}");
    println("Created: " + json_stringify_int(new_user.status_code));
}
