// Concurrency Library - Threads, Channels, Mutexes

// ============= THREAD =============

class Thread {
    var id: int;
    var running: bool;
    
    func spawn(f: func() -> void) -> Thread {
        var thread_id = syscall_thread_create(f);
        return Thread {
            id: thread_id,
            running: true
        };
    }
    
    func join() {
        syscall_thread_join(this.id);
        this.running = false;
    }
    
    func detach() {
        syscall_thread_detach(this.id);
    }
    
    func sleep_ms(ms: int) {
        syscall_sleep(ms);
    }
    
    func yield_now() {
        syscall_thread_yield();
    }
}

// ============= MUTEX =============

class Mutex {
    var locked: bool;
    var lock_id: int;
    
    func new() -> Mutex {
        return Mutex {
            locked: false,
            lock_id: syscall_mutex_create()
        };
    }
    
    func lock() {
        syscall_mutex_lock(this.lock_id);
        this.locked = true;
    }
    
    func unlock() {
        syscall_mutex_unlock(this.lock_id);
        this.locked = false;
    }
    
    func try_lock() -> bool {
        var result = syscall_mutex_trylock(this.lock_id);
        if (result == 0) {
            this.locked = true;
            return true;
        }
        return false;
    }
}

// ============= CHANNEL =============

class Channel<T> {
    var buffer: [T];
    var capacity: int;
    var mutex: Mutex;
    var closed: bool;
    
    func new(capacity: int) -> Channel<T> {
        return Channel<T> {
            buffer: [],
            capacity: capacity,
            mutex: Mutex.new(),
            closed: false
        };
    }
    
    func send(value: T) -> bool {
        this.mutex.lock();
        
        if (this.closed) {
            this.mutex.unlock();
            return false;
        }
        
        // Wait if buffer is full
        while (this.buffer.len() >= this.capacity) {
            this.mutex.unlock();
            Thread.yield_now();
            this.mutex.lock();
            
            if (this.closed) {
                this.mutex.unlock();
                return false;
            }
        }
        
        this.buffer.push(value);
        this.mutex.unlock();
        return true;
    }
    
    func recv() -> T {
        this.mutex.lock();
        
        // Wait if buffer is empty
        while (this.buffer.len() == 0 && !this.closed) {
            this.mutex.unlock();
            Thread.yield_now();
            this.mutex.lock();
        }
        
        if (this.buffer.len() == 0) {
            this.mutex.unlock();
            panic("Channel closed");
        }
        
        var value = this.buffer[0];
        this.buffer = this.buffer[1:];
        
        this.mutex.unlock();
        return value;
    }
    
    func try_recv() -> (bool, T) {
        this.mutex.lock();
        
        if (this.buffer.len() == 0) {
            this.mutex.unlock();
            return (false, default<T>());
        }
        
        var value = this.buffer[0];
        this.buffer = this.buffer[1:];
        
        this.mutex.unlock();
        return (true, value);
    }
    
    func close() {
        this.mutex.lock();
        this.closed = true;
        this.mutex.unlock();
    }
}

// ============= ATOMIC OPERATIONS =============

class Atomic<T> {
    var value: T;
    var mutex: Mutex;
    
    func new(initial: T) -> Atomic<T> {
        return Atomic<T> {
            value: initial,
            mutex: Mutex.new()
        };
    }
    
    func load() -> T {
        this.mutex.lock();
        var v = this.value;
        this.mutex.unlock();
        return v;
    }
    
    func store(new_value: T) {
        this.mutex.lock();
        this.value = new_value;
        this.mutex.unlock();
    }
    
    func swap(new_value: T) -> T {
        this.mutex.lock();
        var old = this.value;
        this.value = new_value;
        this.mutex.unlock();
        return old;
    }
    
    func compare_and_swap(expected: T, new_value: T) -> bool {
        this.mutex.lock();
        
        if (this.value == expected) {
            this.value = new_value;
            this.mutex.unlock();
            return true;
        }
        
        this.mutex.unlock();
        return false;
    }
}

// ============= THREAD POOL =============

class ThreadPool {
    var workers: [Thread];
    var tasks: Channel<func() -> void>;
    var active: bool;
    
    func new(num_threads: int) -> ThreadPool {
        var pool = ThreadPool {
            workers: [],
            tasks: Channel<func() -> void>.new(100),
            active: true
        };
        
        for (var i = 0; i < num_threads; i++) {
            var worker = Thread.spawn(() => {
                pool.worker_loop();
            });
            pool.workers.push(worker);
        }
        
        return pool;
    }
    
    func worker_loop() {
        while (this.active) {
            var (ok, task) = this.tasks.try_recv();
            
            if (ok) {
                task();
            } else {
                Thread.sleep_ms(10);
            }
        }
    }
    
    func execute(task: func() -> void) {
        this.tasks.send(task);
    }
    
    func shutdown() {
        this.active = false;
        this.tasks.close();
        
        for (var worker in this.workers) {
            worker.join();
        }
    }
}

// ============= EXAMPLE USAGE =============

func concurrency_example() {
    // Thread example
    var counter = Atomic<int>.new(0);
    
    var t1 = Thread.spawn(() => {
        for (var i = 0; i < 100; i++) {
            var old = counter.load();
            counter.store(old + 1);
        }
    });
    
    var t2 = Thread.spawn(() => {
        for (var i = 0; i < 100; i++) {
            var old = counter.load();
            counter.store(old + 1);
        }
    });
    
    t1.join();
    t2.join();
    
    println("Counter: " + json_stringify_int(counter.load()));
    
    // Channel example
    var ch = Channel<int>.new(5);
    
    var sender = Thread.spawn(() => {
        for (var i = 0; i < 10; i++) {
            ch.send(i);
        }
        ch.close();
    });
    
    var receiver = Thread.spawn(() => {
        while (true) {
            var (ok, value) = ch.try_recv();
            if (ok) {
                println("Received: " + json_stringify_int(value));
            } else {
                break;
            }
        }
    });
    
    sender.join();
    receiver.join();
    
    // Thread pool example
    var pool = ThreadPool.new(4);
    
    for (var i = 0; i < 20; i++) {
        var task_id = i;
        pool.execute(() => {
            println("Task " + json_stringify_int(task_id) + " executing");
            Thread.sleep_ms(100);
        });
    }
    
    Thread.sleep_ms(3000);
    pool.shutdown();
}
