
println("=== Security & Data Manager Test ===");

var u = "admin";
var p = "admin";

println("Attempting login as admin...");
var success = sec_login(u, p);

if (success == 1) {
    println("Login Success!");
    
    var me = sec_whoami();
    print("Who am I? ");
    println(me);
    
    println("Testing Data Manager...");
    dm_set("last_login", me);
    
    var saved = dm_get("last_login");
    print("Read back 'last_login': ");
    println(saved);
    
    if (me == saved) {
        println("Data Persistence: OK");
    } else {
        println("Data Persistence: FAIL");
    }
    
} else {
    println("Login Failed! (Check password)");
}

println("=== Test Complete ===");
