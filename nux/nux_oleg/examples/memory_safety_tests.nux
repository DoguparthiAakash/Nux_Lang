# Nux Memory Safety Tests
# Comprehensive tests for memory safety features

import {Box, Rc, Arc, RefCell} from "nux/memory_safety.nux";
import {test, expect, describe} from "nux/test.nux";

describe("Memory Safety", func() {
    
    # ===== OWNERSHIP TESTS =====
    
    test("Box ownership transfer", func() {
        var x = new Box(42);
        var y = x;  # Move ownership
        
        expect(y.get()).toBe(42);
        
        # x is now invalid
        expect(func() { x.get(); }).toThrow();
    });
    
    test("Cannot use after drop", func() {
        var x = new Box(42);
        x.drop();
        
        expect(func() { x.get(); }).toThrow("Use after free");
    });
    
    # ===== BORROWING TESTS =====
    
    test("Immutable borrowing", func() {
        var x = new RefCell(42);
        
        var r1 = x.borrow();
        var r2 = x.borrow();  # Multiple immutable borrows OK
        
        expect(r1.get()).toBe(42);
        expect(r2.get()).toBe(42);
        
        r1.drop();
        r2.drop();
    });
    
    test("Mutable borrowing", func() {
        var x = new RefCell(42);
        
        var r = x.borrow_mut();
        r.set(100);
        
        expect(r.get()).toBe(100);
        
        r.drop();
        
        expect(x.borrow().get()).toBe(100);
    });
    
    test("Cannot borrow mutably while immutably borrowed", func() {
        var x = new RefCell(42);
        
        var r1 = x.borrow();
        
        expect(func() {
            x.borrow_mut();
        }).toThrow("Already borrowed");
        
        r1.drop();
    });
    
    test("Cannot borrow immutably while mutably borrowed", func() {
        var x = new RefCell(42);
        
        var r = x.borrow_mut();
        
        expect(func() {
            x.borrow();
        }).toThrow("Already mutably borrowed");
        
        r.drop();
    });
    
    # ===== REFERENCE COUNTING TESTS =====
    
    test("Rc reference counting", func() {
        var x = new Rc([1, 2, 3]);
        
        expect(x.count).toBe(1);
        
        var y = x.clone();
        expect(x.count).toBe(2);
        
        var z = x.clone();
        expect(x.count).toBe(3);
        
        y.drop();
        expect(x.count).toBe(2);
        
        z.drop();
        expect(x.count).toBe(1);
        
        x.drop();
        # Memory freed
    });
    
    test("Arc atomic reference counting", func() {
        var x = new Arc({value: 42});
        
        var y = x.clone();
        var z = x.clone();
        
        expect(x.get().value).toBe(42);
        expect(y.get().value).toBe(42);
        expect(z.get().value).toBe(42);
        
        x.drop();
        y.drop();
        z.drop();
    });
    
    # ===== LIFETIME TESTS =====
    
    test("Borrow does not outlive value", func() {
        var x = new Box(42);
        var r;
        
        {
            r = x.borrow();
            expect(r.get()).toBe(42);
        }
        
        # r should be dropped here
        expect(func() { r.get(); }).toThrow();
    });
    
    # ===== COMPLEX SCENARIOS =====
    
    test("Nested borrowing", func() {
        var x = new RefCell(new RefCell(42));
        
        var outer = x.borrow();
        var inner = outer.get().borrow();
        
        expect(inner.get()).toBe(42);
        
        inner.drop();
        outer.drop();
    });
    
    test("Borrowing in function calls", func() {
        func process(r: Ref<int>): int {
            return r.get() * 2;
        }
        
        var x = new RefCell(21);
        var r = x.borrow();
        
        var result = process(r);
        expect(result).toBe(42);
        
        r.drop();
    });
    
    test("Move semantics", func() {
        func take_ownership(b: Box<int>): int {
            var value = b.get();
            b.drop();
            return value;
        }
        
        var x = new Box(42);
        var result = take_ownership(x);
        
        expect(result).toBe(42);
        
        # x is now invalid
        expect(func() { x.get(); }).toThrow();
    });
    
    # ===== DATA RACE PREVENTION =====
    
    test("No data races with Arc", func() {
        var counter = new Arc(new RefCell(0));
        
        var threads = [];
        
        var i: int = 0;
        while (i < 10) {
            var c = counter.clone();
            
            arr_push(threads, thread_spawn(func() {
                var r = c.get().borrow_mut();
                r.set(r.get() + 1);
                r.drop();
            }));
            
            i = i + 1;
        }
        
        # Wait for all threads
        arr_forEach(threads, func(t) { thread_join(t); });
        
        expect(counter.get().borrow().get()).toBe(10);
        
        counter.drop();
    });
    
    # ===== MEMORY LEAK PREVENTION =====
    
    test("No memory leaks with Rc cycles", func() {
        # This would leak in naive reference counting
        # but we can detect it
        
        var x = new Rc({next: null});
        var y = new Rc({next: x});
        x.get().next = y;  # Create cycle
        
        # Cycle detection should prevent leak
        expect(detect_cycle(x)).toBe(true);
    });
});

# ===== HELPER FUNCTIONS =====

func detect_cycle(rc: Rc<T>): bool {
    var visited = new Set();
    var current = rc;
    
    while (current != null) {
        if (visited.has(current)) {
            return true;  # Cycle detected
        }
        
        visited.add(current);
        current = current.get().next;
    }
    
    return false;
}

# ===== BENCHMARKS =====

func benchmark_memory_safety() {
    var iterations: int = 1000000;
    
    # Benchmark Box
    var start = date_now();
    var i: int = 0;
    while (i < iterations) {
        var x = new Box(i);
        x.drop();
        i = i + 1;
    }
    var box_time = date_now() - start;
    
    # Benchmark Rc
    start = date_now();
    i = 0;
    while (i < iterations) {
        var x = new Rc(i);
        var y = x.clone();
        x.drop();
        y.drop();
        i = i + 1;
    }
    var rc_time = date_now() - start;
    
    # Benchmark RefCell
    start = date_now();
    i = 0;
    while (i < iterations) {
        var x = new RefCell(i);
        var r = x.borrow();
        r.drop();
        i = i + 1;
    }
    var refcell_time = date_now() - start;
    
    print("Box: " + box_time + "ms");
    print("Rc: " + rc_time + "ms");
    print("RefCell: " + refcell_time + "ms");
}

# Run tests
print("Running memory safety tests...");
test_run();
print("All tests passed!");

# Run benchmarks
print("\nRunning benchmarks...");
benchmark_memory_safety();
