# Example Nux Program
# Test program for self-hosting compiler

func fibonacci(n) {
    if (n <= 1) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}

func factorial(n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);
}

func main() {
    print("Nux Self-Hosting Compiler Test");
    print("================================");
    
    # Test variables
    var x: int = 10;
    var y: int = 20;
    var sum = x + y;
    print("10 + 20 = ");
    print(sum);
    
    # Test functions
    var fib10 = fibonacci(10);
    print("Fibonacci(10) = ");
    print(fib10);
    
    var fact5 = factorial(5);
    print("Factorial(5) = ");
    print(fact5);
    
    # Test control flow
    var i: int = 0;
    while (i < 5) {
        print(i);
        i = i + 1;
    }
    
    # Test for loop
    for (var j: int = 0; j < 3; j = j + 1) {
        print("Loop: ");
        print(j);
    }
    
    print("Test complete!");
}

main();
