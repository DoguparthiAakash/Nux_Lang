
var w: int = 4;
var h: int = 2;
var handle = img_alloc(w, h);

# Simulate filling with color in VM (cam_capture does this via bridge)
# Let's just run loop and print indices

println("Start Loop");
var y: int = 0;
var x: int = 0;
while (y < h) {
    print("Row: "); println(y);
    x = 0;
    print("  Check: x="); print(x); print(" w="); println(w);
    while (x < w) {
        print("  Col: "); println(x);
        x = x + 1;
    }
    y = y + 1;
}
println("End Loop");
