# Nux Standard File I/O Library
import "nux.memory";

func File_open(path) {
    var fd = 0;
    asm {
        path
        FILE_OPEN
        POP fd
    }
    return fd;
}

func File_close(fd) {
    asm {
        fd
        FILE_CLOSE
    }
}

func File_read(fd, max_len) {
    var buf = Mem_malloc(max_len + 1);
    var count = 0;
    asm {
        fd
        buf
        max_len
        FILE_READ
        POP count
    }
    if (count < 0) {
        return 0;
    }
    poke(buf + count, 0); 
    return buf;
}

func File_write(fd, s) {
   var len = 0;
   while (peek(s + len) != 0) { len = len + 1; }
   
   var res = 0;
   asm {
       fd
       s
       len
       FILE_WRITE
       POP res
   }
   return res;
}

func File_exists(path) {
    var res = 0;
    asm {
        path
        FILE_EXISTS
        POP res
    }
    return res;
}

func File_mkdir(path) {
    var res = 0;
    asm {
        path
        FILE_MKDIR
        POP res
    }
    return res;
}

func File_delete(path) {
    var res = 0;
    asm {
        path
        FILE_DELETE
        POP res
    }
    return res;
}
