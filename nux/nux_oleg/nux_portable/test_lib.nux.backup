import "lib/math.nux";

# Test the math library with new comment syntax
x = Math_abs(-5);
print("abs(-5) = ");
println(x);

y = Math_max(10, 20);
print("max(10, 20) = ");
println(y);

# Test power using built-in operator
z = 2 ** 8;
print("2 ** 8 = ");
println(z);

# Test floor division
a = 17 // 5;
print("17 // 5 = ");
println(a);
