# Graphics Library
# Wraps Kernel Graphics Opcodes

func draw_text(x, y, s, color) {
    asm {
        color
        s
        y
        x
        GFX_TEXT
    }
}

func draw_rect(x, y, w, h, color) {
    asm {
        color
        h
        w
        y
        x
        GFX_RECT
    }
}

func clear_screen(color) {
    # Full screen rect
    # We might need screen dimensions. For now hardcode or use very large?
    # Better to have GFX_DIMENSIONS opcode or similar, but for now 800x600 or 1024x768.
    # Safe bet: 0, 0, 1920, 1080 (clamped by driver usually)
    draw_rect(0, 0, 1920, 1080, color);
}

