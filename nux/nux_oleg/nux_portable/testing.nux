# Nux Standard Testing Library (Lightweight)
import "lib/util.nux";
import "lib/string.nux";

# Global stats
var __tests_run: int = 0;
var __tests_passed: int = 0;
var __tests_failed: int = 0;

func Assert(cond, msg) {
    if (cond == 0) {
        print("FAIL: ");
        println(msg);
        __tests_failed = __tests_failed + 1;
        # Optional: return 0 to indicate fail
        return 0;
    }
    return 1;
}

func AssertEq(a, b, msg) {
    if (a != b) {
        print("FAIL: ");
        print(msg);
        print(" (Expected "); print(a); print(", got "); print(b); println(")");
        __tests_failed = __tests_failed + 1;
        return 0;
    }
    return 1;
}

func AssertStrEq(s1, s2, msg) {
    if (cmp(s1, s2) != 0) {
        print("FAIL: ");
        println(msg);
        __tests_failed = __tests_failed + 1;
        return 0;
    }
    return 1;
}

func RunTest(name, func_ptr) {
    print("RUN: "); println(name);
    __tests_run = __tests_run + 1;
    
    # We call the function.
    # If it asserts fail, it increments failed.
    # In Nux, we don't have exception catching yet.
    # So we assume if it returns, it "finished".
    # A Panic stops everything (which is fine for fatal).
    
    # Indirect call via asm? 
    # HighLevel Nux doesn't have `call(ptr)` syntax exposed nicely yet.
    # For now, tests are manually invoked in `main` usually.
    # This wrapper is just logging.
    # Future: `asm { PUSH func_ptr; CALL_INDIRECT }` 
    
    # Fallback: User calls Assert inside, we just log "RUN".
}

func Report() {
    print("\n--- Test Report ---\n");
    print("Run: "); println(__tests_run);
    print("Passed: "); println(__tests_run - __tests_failed);
    print("Failed: "); println(__tests_failed);
    
    if (__tests_failed > 0) {
        print("RESULT: FAIL\n");
    } else {
        print("RESULT: PASS\n");
    }
}
