// import "io.nux";

func main() {
    println("--- Nux Type System Test ---");
    
    int id = 101;
    float price = 12.50;
    int qty = 3;
    
    print("Item ID (int): ");
    println(id);
    
    print("Price (float): ");
    println(price);
    
    print("Quantity (int): ");
    println(qty);
    
    // Test Type Promotion
    float total = price * qty; // Float * Int -> Float
    print("Total (float): ");
    println(total);
    
    // Test Explicit Floats
    float tax_rate = 0.10;
    float tax = total * tax_rate;
    print("Tax (float): ");
    println(tax);
    
    float grand_total = total + tax;
    print("Grand Total: ");
    println(grand_total);
    
    // Test Byte/Short (Size aliases)
    byte b = 100;
    print("Byte val: ");
    println(b);
    
    // Test String (Pointer holder/Placeholder)
    // string s = "Hello Types"; // Not fully supported yet in VM but compiles
    
    println("Done.");
}

main();
