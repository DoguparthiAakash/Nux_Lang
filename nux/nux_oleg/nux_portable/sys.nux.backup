# Nux System Library

func exit(code) {
    asm {
        code
        EXIT
    }
}

func platform() {
    # Returns platform name.
    # Currently only "Nux".
    return "Nux Portable";
}

func args() {
    # Should return command line args.
    # Not implemented in kernel args passing yet.
    return 0; 
}

func System(cmd) {
    asm {
        cmd
        SYSTEM
        POP # result code
    }
}
