#* ─────────────────────────────────────────────────────
   Nux Standard Library Test Suite
   Tests all modules: math, algo, ds, mem, io, crypto
   Run with: nux run test_stdlib.nux
   ───────────────────────────────────────────────────── *#

import "std/math.nuxel";
import "std/algo.nuxel";
import "std/ds.nuxel";
import "std/mem.nuxel";
import "std/io.nuxel";
import "std/crypto.nuxel";

func test_math() {
    log("=== MATH LIBRARY ===");

    assert_eq(abs(-42), 42);
    assert_eq(abs(7),   7);
    log_ok("abs");

    assert_eq(min(3, 7),   3);
    assert_eq(max(3, 7),   7);
    assert_eq(clamp(15, 0, 10), 10);
    assert_eq(clamp(-5, 0, 10), 0);
    log_ok("min / max / clamp");

    assert_eq(pow(2, 10), 1024);
    assert_eq(pow(3, 4),   81);
    log_ok("pow");

    assert_eq(sqrt_int(144), 12);
    assert_eq(sqrt_int(99),   9);
    log_ok("sqrt_int");

    assert_eq(factorial(5), 120);
    assert_eq(factorial(0),   1);
    log_ok("factorial");

    assert_eq(fibonacci(10), 55);
    assert_eq(fibonacci(1),   1);
    log_ok("fibonacci");

    assert_eq(gcd(48, 18), 6);
    assert_eq(lcm(4, 6),  12);
    log_ok("gcd / lcm");

    assert_eq(is_prime(2),  1);
    assert_eq(is_prime(17), 1);
    assert_eq(is_prime(18), 0);
    assert_eq(is_prime(1),  0);
    log_ok("is_prime");

    assert_eq(sign(-99), -1);
    assert_eq(sign(0),    0);
    assert_eq(sign(42),   1);
    log_ok("sign");
}

func test_algo() {
    log("=== ALGO LIBRARY ===");

    # Create a test array [5, 3, 8, 1, 9, 2, 7, 4, 6]
    *int arr = alloc(9);
    poke(arr + 0, 5);
    poke(arr + 1, 3);
    poke(arr + 2, 8);
    poke(arr + 3, 1);
    poke(arr + 4, 9);
    poke(arr + 5, 2);
    poke(arr + 6, 7);
    poke(arr + 7, 4);
    poke(arr + 8, 6);

    assert_eq(array_sum(arr, 9), 45);
    assert_eq(array_min(arr, 9),  1);
    assert_eq(array_max(arr, 9),  9);
    assert_eq(array_contains(arr, 9, 7), 1);
    assert_eq(array_contains(arr, 9, 99), 0);
    log_ok("array_sum / min / max / contains");

    assert_eq(linear_search(arr, 9, 8),  2);
    assert_eq(linear_search(arr, 9, 99), -1);
    log_ok("linear_search");

    # Sort and test binary search
    bubble_sort(arr, 9);
    # Should now be [1,2,3,4,5,6,7,8,9]
    assert_eq(peek(arr + 0), 1);
    assert_eq(peek(arr + 8), 9);
    log_ok("bubble_sort");

    assert_eq(binary_search(arr, 9, 5),  4);
    assert_eq(binary_search(arr, 9, 99), -1);
    log_ok("binary_search");

    reverse_arr(arr, 9);
    assert_eq(peek(arr + 0), 9);
    assert_eq(peek(arr + 8), 1);
    log_ok("reverse_arr");

    free(arr);
}

func test_ds() {
    log("=== DATA STRUCTURES ===");

    # Stack
    var s = stack_new(8);
    stack_push(s, 10);
    stack_push(s, 20);
    stack_push(s, 30);
    assert_eq(stack_size(s), 3);
    assert_eq(stack_pop(s),  30);
    assert_eq(stack_pop(s),  20);
    assert_eq(stack_size(s),  1);
    stack_free(s);
    log_ok("Stack");

    # Queue
    var q = queue_new(8);
    queue_enqueue(q, 100);
    queue_enqueue(q, 200);
    queue_enqueue(q, 300);
    assert_eq(queue_size(q),    3);
    assert_eq(queue_dequeue(q), 100);
    assert_eq(queue_dequeue(q), 200);
    assert_eq(queue_size(q),    1);
    queue_free(q);
    log_ok("Queue");

    # Linked list
    var head = 0;
    head = list_append(head, 10);
    head = list_append(head, 20);
    head = list_append(head, 30);
    assert_eq(list_len(head),    3);
    assert_eq(list_get(head, 0), 10);
    assert_eq(list_get(head, 2), 30);
    list_free(head);
    log_ok("Linked List");

    # Hash map
    var m = map_new(16);
    map_set(m, 1, 100);
    map_set(m, 2, 200);
    map_set(m, 3, 300);
    assert_eq(map_get(m, 1),  100);
    assert_eq(map_get(m, 3),  300);
    assert_eq(map_has(m, 2),    1);
    assert_eq(map_has(m, 99),   0);
    assert_eq(map_count(m),     3);
    map_free(m);
    log_ok("Hash Map");
}

func test_mem() {
    log("=== MEMORY LIBRARY ===");

    *int src = alloc(4);
    *int dst = alloc(4);

    poke(src + 0, 10);
    poke(src + 1, 20);
    poke(src + 2, 30);
    poke(src + 3, 40);

    memcpy(dst, src, 4);
    assert_eq(peek(dst + 0), 10);
    assert_eq(peek(dst + 3), 40);
    assert_eq(memcmp(src, dst, 4), 0);
    log_ok("memcpy / memcmp");

    memset(dst, 4, 99);
    assert_eq(peek(dst + 0), 99);
    assert_eq(peek(dst + 3), 99);
    log_ok("memset");

    free(src);
    free(dst);

    # Arena allocator
    var arena = arena_new(64);
    var p1 = arena_alloc(arena, 8);
    var p2 = arena_alloc(arena, 8);
    assert_neq(p1, p2);
    assert_eq(arena_used(arena), 16);
    arena_reset(arena);
    assert_eq(arena_used(arena), 0);
    arena_free(arena);
    log_ok("Arena allocator");
}

func test_crypto() {
    log("=== CRYPTO LIBRARY ===");

    # PRNG
    srand(42);
    var r1 = rand_range(100);
    var r2 = rand_range(100);
    log_val("rand1", r1);
    log_val("rand2", r2);
    log_ok("PRNG");

    # DJB2 hash
    *int data = alloc(4);
    poke(data + 0, 72);    # 'H'
    poke(data + 1, 101);   # 'e'
    poke(data + 2, 108);   # 'l'
    poke(data + 3, 108);   # 'l'
    var h = djb2_hash(data, 4);
    log_val("djb2_hash", h);
    log_ok("DJB2 hash");

    # CRC8
    var crc = crc8(data, 4);
    log_val("crc8", crc);
    log_ok("CRC-8");

    free(data);
}

func main() {
    println("====================================");
    println("  Nux Standard Library Test Suite");
    println("====================================");

    test_math();
    test_algo();
    test_ds();
    test_mem();
    test_crypto();

    println("");
    println("[ALL TESTS PASSED]");
}

main();
