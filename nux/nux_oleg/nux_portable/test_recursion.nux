func fib(n) {
    if (n <= 1) {
        return n;
    }
    return fib(n-1) + fib(n-2);
}

func main() {
    var n: int = 10;
    var res = fib(n);
    print("Fib(10) = ");
    println(res);
    
    # Check if Locals work
    var a: int = 100;
    var b: int = 200;
    var c = a + b;
    print("100+200=");
    println(c);
}

main();
