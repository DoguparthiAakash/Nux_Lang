import "lib/io.nux";

func main() {
    println("--- Testing Else If ---");
    
    var x: int = 20;
    
    if (x < 10) {
        println("x is < 10");
    } else if (x == 10) {
        println("x is 10");
    } else if (x == 20) {
        println("x is 20 (Correct)");
    } else {
        println("x is > 20");
    }
    
    println("Done.");
}

main();
