import "ai"
import "alloc"

func main() {
    alloc_init(116, 1000000);
    # XOR problem setup
    var in_size = 2;
    var hidden_size = 2;
    var out_size = 1;
    
    # inputs: [1.0, 0.0] -> [1000, 0]
    var inputs = alloc(in_size * 8);
    poke(inputs + 0, 1000);
    poke(inputs + 8, 0);
    
    # hidden layer weights (in_size * hidden_size)
    var h_weights = alloc(in_size * hidden_size * 8);
    poke(h_weights + 0, 500); poke(h_weights + 8, 0 - 500);
    poke(h_weights + 16, 0 - 500); poke(h_weights + 24, 500);
    
    # hidden layer biases
    var h_biases = alloc(hidden_size * 8);
    poke(h_biases + 0, 0);
    poke(h_biases + 8, 0);
    
    # hidden layer outputs
    var h_outputs = alloc(hidden_size * 8);
    
    # output layer weights
    var o_weights = alloc(hidden_size * out_size * 8);
    poke(o_weights + 0, 1000); poke(o_weights + 8, 1000);
    
    var o_biases = alloc(out_size * 8);
    poke(o_biases + 0, 0);
    
    var final_outputs = alloc(out_size * 8);
    
    # Forward pass
    layer_forward(inputs, h_weights, h_biases, h_outputs, in_size, hidden_size);
    layer_forward(h_outputs, o_weights, o_biases, final_outputs, hidden_size, out_size);
    
    # Print final output
    var result = peek(final_outputs + 0);
    println(result);
}
