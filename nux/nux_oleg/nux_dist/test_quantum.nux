import "std/openql";

func main() {
    print("Testing Quantum Register...\n");
    var qreg = new QRegister();
    qreg.init(2); // 2 qubits
    
    // Entangle qubit 0 and qubit 1
    print("Entangling qubits...\n");
    qreg.entangle(0, 1);
    
    print("Measuring...\n");
    var c0 = qreg.measure(0);
    var c1 = qreg.measure(1);
    
    print("Qubit 0: ");
    print(c0);
    print("\nQubit 1: ");
    print(c1);
    print("\nDone.\n");
}
main();
