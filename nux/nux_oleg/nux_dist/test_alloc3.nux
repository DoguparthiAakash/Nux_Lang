import "alloc"

func fib_iter(n) {
    if (n <= 1) { return n; }
    var a = 0; var b = 1;
    for (var i = 2; i <= n; i = i + 1) {
        var c = a + b; a = b; b = c;
    }
    return b;
}

func main() {
    var f10 = fib_iter(10);
    print("fib(10)="); println(f10);
    alloc_init(20000, 4000);
    var b1 = alloc(8);
    var b2 = alloc(8);
    print("b1="); println(b1);
    print("b2="); println(b2);
    poke(b1, 999);
    poke(b2, 777);
    print("peek(b1)="); println(peek(b1));
    print("peek(b2)="); println(peek(b2));
}
