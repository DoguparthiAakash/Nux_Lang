func add(a, b) {
    return a + b;
}

func counter(n) {
    var s = 0;
    var i = 0;
    while (i < n) {
        print("i=");
        println(i);
        s = s + 1;
        i = i + 1;
    }
    return s;
}

func main() {
    # Direct arg access
    var r1 = add(3, 5);
    print("add(3,5)=");
    println(r1);

    # Simple local var
    var x = 42;
    print("x=");
    println(x);

    # While loop with locals
    var c = counter(10);
    print("counter(10)=");
    println(c);
}
