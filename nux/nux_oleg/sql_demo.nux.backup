# Nux SQL Demo

import "external.data.sql";

func main() {
    print("Initializing SQL Database...");
    
    var conn = new Connection();
    conn.init("testdb");
    
    # 1. Create Table
    print("Creating table 'users'...");
    # Simple syntax: CREATE TABLE users (id, name, role)
    # Our simple parser ignores columns for now, just creates file
    conn.execute("CREATE TABLE users (id, name, role)");
    
    # 2. Insert Data
    print("Inserting data...");
    # We use JSON format for values in our simplified implementation
    conn.execute("INSERT INTO users VALUES {\"id\":1, \"name\":\"Admin\", \"role\":\"admin\"}");
    conn.execute("INSERT INTO users VALUES {\"id\":2, \"name\":\"Bob\", \"role\":\"user\"}");
    conn.execute("INSERT INTO users VALUES {\"id\":3, \"name\":\"Charlie\", \"role\":\"user\"}");
    
    # 3. Select All
    print("Selecting all users...");
    var rs = conn.execute("SELECT * FROM users");
    
    while (rs.next()) {
        var row = rs.get_row();
        # Print JSON string representation
        # print("Row: " + json_stringify(row));
        
        # Access columns
        var name = rs.get("name");
        var role = rs.get("role");
        print("User: " + name + " (" + role + ")");
    }
    
    # 4. Select Where
    print("Selecting admins...");
    var rs_admin = conn.execute("SELECT * FROM users WHERE role=admin");
    # Note: simple parser might need quotes for strings or handle them raw. 
    # Current impl splits by '=' so 'role=admin' works if json has "admin" (might fail type check)
    # Let's hope loose comparison works or we update logic.
    
    while (rs_admin.next()) {
        print("Admin Found: " + rs_admin.get("name"));
    }
}

main();
