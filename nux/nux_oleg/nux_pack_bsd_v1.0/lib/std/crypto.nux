func crypto_hexEncode(bytes) {
    # Hex encode bytes
    var result: string = "";
    var i: int = 0;
    var hexChars: string = "0123456789abcdef";
    
    while (i < arr_length(bytes)) {
        var byte = bytes[i];
        var high = byte / 16;
        var low = byte % 16;
        result = result + hexChars[high] + hexChars[low];
        i = i + 1;
    }
    
    return result;
}

func crypto_hexDecode(hex) {
    # Hex decode to bytes
    var bytes = [];
    var i: int = 0;
    
    while (i < str_length(hex)) {
        var high = crypto_hexCharToInt(hex[i]);
        var low = crypto_hexCharToInt(hex[i + 1]);
        bytes[i / 2] = high * 16 + low;
        i = i + 2;
    }
    
    return bytes;
}

func crypto_hexCharToInt(char) {
    # Convert hex character to integer
    if (char >= "0" && char <= "9") {
        return char - "0";
    }
    if (char >= "a" && char <= "f") {
        return char - "a" + 10;
    }
    if (char >= "A" && char <= "F") {
        return char - "A" + 10;
    }
    return 0;
}

# ===== RANDOM =====

func crypto_randomBytes(count) {
    # Generate cryptographically secure random bytes
    # TODO: Implement with VM crypto support
    var bytes = [];
    var i: int = 0;
    
    while (i < count) {
        bytes[i] = randomInt(0, 255);
        i = i + 1;
    }
    
    return bytes;
}

func crypto_uuid() {
    # Generate UUID v4
    var bytes = crypto_randomBytes(16);
    
    # Set version (4) and variant bits
    bytes[6] = (bytes[6] & 0x0f) | 0x40;
    bytes[8] = (bytes[8] & 0x3f) | 0x80;
    
    var hex = crypto_hexEncode(bytes);
    
    # Format as UUID
    var part1 = str_substring(hex, 0, 8);
    var part2 = str_substring(hex, 8, 12);
    var part3 = str_substring(hex, 12, 16);
    var part4 = str_substring(hex, 16, 20);
    var part5 = str_substring(hex, 20, 32);
    
    return part1 + "-" + part2 + "-" + part3 + "-" + part4 + "-" + part5;
}

func crypto_randomString(length) {
    # Generate random alphanumeric string
    var chars: string = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
    var result: string = "";
    var i: int = 0;
    
    while (i < length) {
        var index = randomInt(0, str_length(chars) - 1);
        result = result + chars[index];
        i = i + 1;
    }
    
    return result;
}

# ===== UTILITY =====

func crypto_hash(data, algorithm) {
    # Generic hash function
    if (algorithm == "md5") {
        return crypto_md5(data);
    } else if (algorithm == "sha1") {
        return crypto_sha1(data);
    } else if (algorithm == "sha256") {
        return crypto_sha256(data);
    } else if (algorithm == "sha512") {
        return crypto_sha512(data);
    }
    return "";
}

func crypto_compareHash(data, hash, algorithm) {
    # Compare data hash with expected hash
    var computed = crypto_hash(data, algorithm);
    return computed == hash;
}
