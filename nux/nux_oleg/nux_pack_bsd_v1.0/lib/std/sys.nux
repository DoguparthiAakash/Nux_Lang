# ===== UTILITY =====

func sys_isWindows() {
    return sys_platform() == "windows";
}

func sys_isLinux() {
    return sys_platform() == "linux";
}

func sys_isMacOS() {
    return sys_platform() == "macos";
}

func sys_isX64() {
    return sys_arch() == "x64";
}

func sys_isARM() {
    var arch = sys_arch();
    return arch == "arm64" || arch == "arm";
}
