# ===== PLATFORM INFORMATION =====

func sys_platform() {
    # Get OS platform (linux/windows/macos)
    # TODO: Implement with VM system support
    return "linux";
}

func sys_arch() {
    # Get CPU architecture (x64/arm64/x86)
    # TODO: Implement with VM system support
    return "x64";
}

func sys_hostname() {
    # Get system hostname
    # TODO: Implement with VM system support
    return "localhost";
}

func sys_username() {
    # Get current username
    # TODO: Implement with VM system support
    return "user";
}

func sys_homedir() {
    # Get user home directory
    # TODO: Implement with VM system support
    return "/home/user";
}

func sys_tmpdir() {
    # Get temporary directory
    # TODO: Implement with VM system support
    return "/tmp";
}

