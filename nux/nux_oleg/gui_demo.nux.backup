# Nux GUI Demo

import "external.gui.gui";
import "external.game.gfxdriver";

func main() {
    # 1. Initialize Graphics Driver
    # Create a mock framebuffer for specialized testing or use real one
    var width = 800;
    var height = 600;
    
    # In a real environment we would likely do:
    # var vbe = vbe_set_mode(width, height, 32);
    # var fb_addr = vbe_get_framebuffer();
    # var fb = new Framebuffer();
    # fb.init(fb_addr, width, height, width * 4, 32);
    
    # For this syntax check/demo, we'll mock the FB object
    class MockFramebuffer {
        var width;
        var height;
        func init(w, h) { this.width = w; this.height = h; }
        func fill_rect(x, y, w, h, c) { print("Fill Rect: " + x + "," + y); }
        func draw_line(x1, y1, x2, y2, c) { print("Line: " + x1 + "," + y1); }
    }
    
    var fb = new MockFramebuffer();
    fb.init(width, height);
    
    # 2. Initialize GUI
    var gui = new Gui();
    gui.init(fb);
    
    # 3. Create a Window
    var win = new Window();
    win.init(100, 100, 400, 300, "My Application");
    
    # 4. Add Widgets
    var btn = new Button();
    btn.init(50, 50, 100, 30, "Click Me");
    
    # Callback
    # Nux might not support closures fully yet, so we define a function
    # func on_click() { print("Button Clicked!"); }
    # btn.set_callback(on_click);
    
    win.add_child(btn);
    
    var label = new Label();
    label.init(50, 100, "Hello GUI World");
    win.add_child(label);
    
    # 5. Add Window to GUI
    gui.add_window(win);
    
    # 6. Simulate Event Loop
    print("Rendering GUI...");
    gui.render();
    
    print("Simulating Click at (160, 160)...");
    # Window at 100,100. Button at 50,50 relative -> 150,150 global.
    # Button size 100x30 -> 150-250 x 150-180.
    # Click at 160, 160 should hit button.
    
    gui.on_mouse_click(160, 160);
}

main();
