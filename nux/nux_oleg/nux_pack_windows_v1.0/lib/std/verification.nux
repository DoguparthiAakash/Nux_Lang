# ===== ASSERTIONS =====

func assert_invariant(condition, message) {
    # Runtime assertion
    if (!condition) {
        print("Assertion failed: " + message);
        sys_exit(1);
    }
}

func assert_pre(condition, message) {
    # Precondition assertion
    if (!condition) {
        print("Precondition failed: " + message);
        sys_exit(1);
    }
}

func assert_post(condition, message) {
    # Postcondition assertion
    if (!condition) {
        print("Postcondition failed: " + message);
        sys_exit(1);
    }
}

# ===== REFINEMENT TYPES =====

func refine_type(baseType, predicate) {
    # Create refinement type
    return {
        base: baseType,
        refinement: predicate
    };
}

func refine_check(value, refinedType) {
    # Check if value satisfies refinement
    return refinedType.refinement(value);
}

# Example: Positive integers
func type_PositiveInt() {
    return refine_type("int", func(x) { return x > 0; });
}

# Example: Non-empty array
func type_NonEmptyArray() {
    return refine_type("array", func(arr) { return arr_length(arr) > 0; });
}

# ===== DEPENDENT TYPES =====

func dependent_type(name, dependency) {
    # Create dependent type
    return {
        name: name,
        dependency: dependency
    };
}

# Example: Vector of length n
func type_Vector(n) {
    return dependent_type("Vector", {
        length: n,
        check: func(vec) { return arr_length(vec) == n; }
    });
}

# ===== PROGRAM ANALYSIS =====

func analyze_reachability(cfg, start, target) {
    # Reachability analysis
    var visited = set_create();
    var queue = [start];
    
    while (arr_length(queue) > 0) {
        var node = arr_shift(queue);
        
        if (node == target) {
            return true;
        }
        
        if (!set_has(visited, node)) {
            set_add(visited, node);
            
            # Add successors
            var successors = cfg.edges[node] || [];
            arr_forEach(successors, func(succ) {
                arr_push(queue, succ);
            });
        }
    }
    
    return false;
}

