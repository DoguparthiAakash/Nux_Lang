{
    "Main Function": {
        "prefix": "main",
        "body": [
            "func main() {",
            "    $1",
            "}"
        ],
        "description": "Main function template"
    },
    "Function": {
        "prefix": "func",
        "body": [
            "func ${1:name}(${2:args}) {",
            "    $0",
            "}"
        ],
        "description": "Function definition"
    },
    "Class": {
        "prefix": "class",
        "body": [
            "class ${1:Name} {",
            "    $0",
            "}"
        ],
        "description": "Class definition"
    },
    "Import": {
        "prefix": "import",
        "body": [
            "import \"${1:nux.io}\";"
        ],
        "description": "Import statement"
    },
    "Print Line": {
        "prefix": "pl",
        "body": [
            "println(\"${1:text}\");"
        ],
        "description": "Print line statement"
    },
    "If Statement": {
        "prefix": "if",
        "body": [
            "if (${1:condition}) {",
            "    $0",
            "}"
        ],
        "description": "If statement"
    },
    "For Loop": {
        "prefix": "for",
        "body": [
            "for (var ${1:i} = 0; ${1:i} < ${2:count}; ${1:i} = ${1:i} + 1) {",
            "    $0",
            "}"
        ],
        "description": "For loop"
    },
    "While Loop": {
        "prefix": "while",
        "body": [
            "while (${1:condition}) {",
            "    $0",
            "}"
        ],
        "description": "While loop"
    }
}