{
    "name": "nux-lang",
    "displayName": "Nux Language",
    "description": "Language support for Nux",
    "version": "0.0.1",
    "icon": "icons/logo.png",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "nux",
                "aliases": [
                    "Nux",
                    "nux"
                ],
                "extensions": [
                    ".nux"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/logo.png",
                    "dark": "./icons/logo.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "nux",
                "scopeName": "source.nux",
                "path": "./syntaxes/nux.tmLanguage.json"
            }
        ]
    }
}