{
    "scopeName": "source.nux",
    "name": "Nux",
    "patterns": [
        {
            "comment": "Multi-line comments",
            "begin": "#\\*",
            "end": "\\*#",
            "name": "comment.block.nux"
        },
        {
            "comment": "Line comments",
            "match": "//.*",
            "name": "comment.line.double-slash.nux"
        },
        {
            "comment": "Keywords",
            "match": "\\b(if|else|while|for|return|break|continue|import|class|func|let|const|var|new|this|async|await|try|catch|throw|defer|match|enum|trait|asm|unsafe|syscall|peek_ptr|poke_ptr)\\b",
            "name": "keyword.control.nux"
        },
        {
            "comment": "Types",
            "match": "\\b(int|float|string|bool|void|any|Exception|Array)\\b",
            "name": "storage.type.nux"
        },
        {
            "comment": "Function definition",
            "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
            "captures": {
                "1": {
                    "name": "keyword.declaration.function.nux"
                },
                "2": {
                    "name": "entity.name.function.nux"
                }
            }
        },
        {
            "comment": "Function calls with optional namespaces",
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*(?:::[a-zA-Z_][a-zA-Z0-9_]*)*)\\s*(?=\\()",
            "name": "entity.name.function.call.nux"
        },
        {
            "comment": "Strings",
            "begin": "\"",
            "end": "\"",
            "name": "string.quoted.double.nux",
            "patterns": [
                {
                    "match": "\\\\.",
                    "name": "constant.character.escape.nux"
                }
            ]
        },
        {
            "comment": "Numbers",
            "match": "\\b\\d+(\\.\\d+)?\\b",
            "name": "constant.numeric.nux"
        },
        {
            "comment": "Booleans",
            "match": "\\b(true|false)\\b",
            "name": "constant.language.boolean.nux"
        },
        {
            "comment": "Operators",
            "match": "(\\+|-|\\*|/|%|=|==|!=|<|>|<=|>=|&&|\\|\\||!|::|=>)",
            "name": "keyword.operator.nux"
        },
        {
            "comment": "Punctuation",
            "match": "(\\{|\\}|\\[|\\]|\\(|\\)|;|,|\\.)",
            "name": "punctuation.nux"
        }
    ]
}