func lang_complement(fa) {
    # Complement of language
    var complementAccepting = arr_filter(fa.states, func(state) {
        return !arr_includes(fa.accepting, state);
    });
    
    return fa_create(
        fa.states,
        fa.alphabet,
        fa.transitions,
        fa.initial,
        complementAccepting
    );
}
