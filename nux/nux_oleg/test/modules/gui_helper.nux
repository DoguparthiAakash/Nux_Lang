# Nux Module: GUI Helper
# Helper class for creating standard windows

import "external.gui.gui";

class WindowFactory {
    func create_alert_window(title, message) {
        var win = new Window();
        win.init(100, 100, 300, 150, title);
        
        var label = new Label();
        label.init(20, 40, message);
        win.add_child(label);
        
        var btn = new Button();
        btn.init(100, 100, 80, 30, "OK");
        win.add_child(btn);
        
        return win;
    }
}
