# Data Service Module
# Handles SQL operations

import "external.data.sql";

class DataService {
    var conn;
    
    func init(db_name) {
        this.conn = new Connection();
        this.conn.init(db_name);
    }
    
    func setup() {
        this.conn.execute("CREATE TABLE products (id, name, price)");
        this.conn.execute("INSERT INTO products VALUES {\"id\":1, \"name\":\"Laptop\", \"price\":999}");
        this.conn.execute("INSERT INTO products VALUES {\"id\":2, \"name\":\"Phone\", \"price\":599}");
        this.conn.execute("INSERT INTO products VALUES {\"id\":3, \"name\":\"Tablet\", \"price\":299}");
    }
    
    func get_products() {
        return this.conn.execute("SELECT * FROM products");
    }
}
