# Nux GUI Test
# Scenario: Single Library, Single File
# Verifies basic window and widget creation

import "external.gui.gui";

# Mock FB for headless test
class MockFB {
    var width; 
    var height;
    func init(w, h) { this.width = w; this.height = h; }
    func fill_rect(x, y, w, h, c) {}
    func draw_line(x1, y1, x2, y2, c) {}
}

func main() {
    print("Running GUI Single Lib Test...");
    
    var fb = new MockFB();
    fb.init(800, 600);
    
    var gui = new Gui();
    gui.init(fb);
    
    var win = new Window();
    win.init(10, 10, 200, 100, "Test Window");
    
    var btn = new Button();
    btn.init(5, 5, 80, 30, "OK");
    
    win.add_child(btn);
    gui.add_window(win);
    
    gui.render();
    print("GUI Test Passed.");
}

main();
