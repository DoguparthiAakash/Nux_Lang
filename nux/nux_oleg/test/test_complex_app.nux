# Nux Complex Application Test
# Scenario: Multiple Libraries, Multiple Files Linked
# Integrates SQL and GUI across different modules

import "modules.data_service";
import "modules.ui_service";

# Mock FB
class MockFB {
    var width; 
    var height;
    func init(w, h) { this.width = w; this.height = h; }
    func fill_rect(x, y, w, h, c) {}
    func draw_line(x1, y1, x2, y2, c) {}
}

func main() {
    print("Running Complex App Test...");
    
    # 1. Initialize Data Service
    var data_svc = new DataService();
    data_svc.init("shop_db");
    data_svc.setup();
    
    # 2. Get Data
    var products = data_svc.get_products();
    
    # 3. Initialize UI Service
    var fb = new MockFB();
    fb.init(1024, 768);
    var ui_svc = new UIService();
    ui_svc.init(fb);
    
    # 4. Display Data
    ui_svc.create_product_window(products);
    ui_svc.render();
    
    print("Complex App Test Passed.");
}

main();
