# Nux Markdown Test
# Scenario: Single Library, Single File
# Verifies markdown parsing

import "nux.markdown";

func main() {
    print("Running Markdown Single Lib Test...");
    
    var md = new MarkdownParser();
    md.init();
    
    var text: string = "# Heading\n**Bold** text";
    var html = md.parse(text);
    
    # Basic check
    # Check if html contains <h1> and <b>
    # We lack std.string.contains in this context unless we import std.string
    # But since std.markdown imports std.string, we might have it available in scope if translucent?
    # No, usually need explicit import.
    
    # Let's just print
    print("Parsed HTML: " + html);
}

main();
