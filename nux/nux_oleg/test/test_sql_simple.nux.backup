# Nux SQL Test
# Scenario: Single Library, Single File
# Verifies basic SQL operations

import "external.data.sql";

func main() {
    print("Running SQL Single Lib Test...");
    
    var conn = new Connection();
    conn.init("simple_test_db");
    
    # 1. Create
    conn.execute("CREATE TABLE items (id, name)");
    
    # 2. Insert
    conn.execute("INSERT INTO items VALUES {\"id\":101, \"name\":\"Widget A\"}");
    
    # 3. Select
    var rs = conn.execute("SELECT * FROM items");
    
    var found = 0;
    while (rs.next()) {
        if (rs.get("name") == "Widget A") {
            found = 1;
        }
    }
    
    if (found == 1) {
        print("SQL Test Passed: Item found.");
    } else {
        print("SQL Test Failed: Item not found.");
    }
}

main();
