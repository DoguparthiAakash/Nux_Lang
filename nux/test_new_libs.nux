import "io";
import "time";
import "math";
import "collections";

func main() {
    println("Testing Nux Extensions...");
    
    # 1. Test Time
    print("Current Ticks: ");
    var t = Now();
    print_val(t);
    println("");
    
    # 2. Test Random
    print("Random: ");
    var r = Math_random();
    print_val(r);
    println("");
    
    # 3. Test Trig
    print("Sin(0): ");
    var s0 = Math_sin(0.0);
    print_float(s0);
    println("");
    
    print("Cos(0): ");
    var c0 = Math_cos(0.0);
    print_float(c0);
    println("");
    
    # 4. Test Collections
    var list = List_new(5);
    List_push(list, 10);
    List_push(list, 20);
    List_push(list, 30);
    
    print("List Len: ");
    print_val(List_len(list));
    println("");
    
    var popped = List_pop(list);
    print("Popped: ");
    print_val(popped);
    println("");
    
    print("List Len After Pop: ");
    print_val(List_len(list));
    println("");
    
    println("Done.");
}
