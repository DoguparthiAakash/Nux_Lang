use std::io::{self};
use std::fs;

pub fn run(filename: &str) {
    let content = std::fs::read_to_string(filename).unwrap_or_default();
    let _cursor = 0;
    
    // Raw mode would be ideal but complex without crates.
    // We will use a line-based loop or naive buffer read.
    // Since we can't easily enable raw mode in std without crates (need termios/windows API),
    // we will implement a "Line Editor" or rely on system editor if possible?
    // User asked "create an ide".
    // Best effort: Clear screen, print content, ask for *entire new content* or specific line edit?
    // Doing a real TUI without `termios` raw mode on Linux is impossible (enter key buffering).
    
    // We will spawn `nano` or `vi` if available?
    // User wants *in it*.
    
    // Let's assume we can try to call standard editors.
    // If not, we provide a very simple "Append/Write" interface.
    
    println!("Nux IDE - Editing: {}", filename);
    println!("Typing content. Type ':wq' on a new line to save and exit.");
    println!("------------------------------------------------------------");
    print!("{}", content);
    
    let mut input = String::new();
    let stdin = io::stdin();
    
    // If file existed, we are in append mode effectively unless we rewrite.
    // Let's just read full input and overwrite.
    // This is "IDE" level 0.1
    
    if !content.is_empty() {
        println!("\n[Warning: Overwriting mode. Old content displayed above.]");
        input = String::new(); // Fresh start or maybe keep old?
        // Simpler: Just allow user to type the file.
    }

    loop {
        let mut line = String::new();
        stdin.read_line(&mut line).unwrap();
        if line.trim() == ":wq" {
            break;
        }
        input.push_str(&line);
    }
    
    fs::write(filename, input).expect("Unable to save file");
    println!("File saved.");
}
