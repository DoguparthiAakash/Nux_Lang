import "io.nux";

func main() {
    println("--- Testing While Loop ---");
    var i = 0;
    while (i < 3) {
        print("While: ");
        println(i);
        i = i + 1;
    }

    println("--- Testing Do-While Loop ---");
    var j = 0;
    do {
        print("Do-While: ");
        println(j);
        j = j + 1;
    } while (j < 3);

    println("--- Testing For Loop ---");
    // Standard C-style for
    for (var k = 0; k < 3; k = k + 1) {
        print("For: ");
        println(k);
    }
    
    println("Done.");
}

main();
