# Camera Color Counter (Main Wrapper)

func main() {
    println("--- Nux Color Counter ---");

    var w = 32;
    var h = 16;
    println("Allocating buffer...");
    var w = 32;
    var h = 16;
    println("Allocating buffer...");
    var handle = img_alloc(w, h);

    var loop_count = 0;
    
    # Pre-declare loop vars to avoid stack leak bug in v0.3
    var r_count = 0;
    var g_count = 0;
    var b_count = 0;
    var y = 0;
    var x = 0;
    var px = 0;
    var r = 0;
    var g = 0;
    var b = 0;

    while (loop_count < 5) {
        # Capture Frame
        cam_capture(handle);
        
        # Reset Counters
        r_count = 0;
        g_count = 0;
        b_count = 0;
        
        y = 0;
        while (y < h) {
            x = 0;
            while (x < w) {
                px = img_get(handle, x, y);
                
                # Extract Components (ARGB) using Math (Bitwise not impl)
                # r = (px >> 16) & 255
                r = (px // 65536) % 256;
                # g = (px >> 8) & 255
                g = (px // 256) % 256;
                # b = px & 255
                b = px % 256;
                
                # Determine Dominant Color
                if (r > g) {
                    if (r > b) { r_count = r_count + 1; }
                }
                if (g > r) {
                    if (g > b) { g_count = g_count + 1; }
                }
                if (b > r) {
                    if (b > g) { b_count = b_count + 1; }
                }
                
                x = x + 1;
            }
            y = y + 1;
        }
        
        # Display
        img_draw(handle);
        
        print("Stats [Frame "); print(loop_count); print("]: ");
        print("R: "); print(r_count);
        print(" - G: "); print(g_count);
        print(" - B: "); println(b_count);
        
        loop_count = loop_count + 1;
    }

    img_free(handle);
    println("Done.");
}

main();
