# Test math functions directly without import

func Math_abs(x) {
    if (x < 0) {
        return 0 - x;
    }
    return x;
}

func Math_max(a, b) {
    if (a > b) {
        return a;
    }
    return b;
}

# Test the functions
x = Math_abs(-5);
print("abs(-5) = ");
println(x);

y = Math_max(10, 20);
print("max(10, 20) = ");
println(y);

# Test power using built-in operator
z = 2 ** 8;
print("2 ** 8 = ");
println(z);

# Test floor division
a = 17 // 5;
print("17 // 5 = ");
println(a);
