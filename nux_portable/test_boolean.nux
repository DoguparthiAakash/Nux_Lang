# Test Boolean Logic

func main() {
    println("--- Boolean Logic Test ---");

    var t = true;
    var f = false;

    print("true: ");
    println(t); # Should be 1
    
    print("false: ");
    println(f); # Should be 0

    print("not true: ");
    println(not t); # Should be 0

    print("not false: ");
    println(not f); # Should be 1
    
    # Logic
    print("true and true: ");
    println(true and true); # 1
    
    print("true and false: ");
    println(true and false); # 0
    
    print("false or true: ");
    println(false or true); # 1
    
    print("false or false: ");
    println(false or false); # 0
    
    # Complex
    print("(not false) and true: ");
    println((not false) and true); # 1
    
    if (true) {
        println("If(true) works.");
    }
    
    if (not false) {
        println("If(not false) works.");
    }
}

main();
